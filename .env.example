# OpenAI API key — required for image generation (DALL-E 3)
OPENAI_API_KEY=sk-...

# Google AdSense publisher ID — required for ad monetization
# Format: pub-XXXXXXXXXXXXXXXX (16 digits)
# Get this from your AdSense account: https://www.google.com/adsense
PUBLIC_ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX

# Optional: path to the Astro project root
# Defaults to auto-detected parent of scripts/ directory
# ASTRO_ROOT=/path/to/coloriages
