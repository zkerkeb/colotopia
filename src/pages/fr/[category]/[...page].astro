---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringCard from '../../../components/ColoringCard.astro';
import AdSlot from '../../../components/AdSlot.astro';
import Pagination from '../../../components/Pagination.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PillarSection from '../../../components/PillarSection.astro';
import CategoryFaq from '../../../components/CategoryFaq.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { categories, adultCategories, getCategoryLabel, getCategorySlug, ti, categoryIcons, categoryColors, type Category } from '../../../lib/i18n';
import { getPublishableColoriages } from '../../../lib/coloriages';
import { getPillarContent } from '../../../data/pillar-content';

const locale = 'fr';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const results = [];
  const allColoriages = await getPublishableColoriages('fr');
  for (const cat of categories) {
    const coloriages = allColoriages.filter((c) => c.data.category === cat);
    if (coloriages.length === 0) continue;
    const pages = paginate(coloriages, {
      params: { category: cat },
      props: { categoryKey: cat },
      pageSize: 24,
    });
    results.push(...pages);
  }
  return results;
}

const { page, categoryKey } = Astro.props as { page: any; categoryKey: Category };
const label = getCategoryLabel(categoryKey, locale);
const isAdult = (adultCategories as readonly string[]).includes(categoryKey);
const catIcon = categoryIcons[categoryKey];
const catColor = categoryColors[categoryKey];
const pillar = page.currentPage === 1 ? getPillarContent(categoryKey, locale) : null;

const descriptionKey = isAdult ? 'category.description.adults' : 'category.description';
const pageDescription = pillar
  ? pillar.intro.slice(0, 160).replace(/\s+\S*$/, '…')
  : ti(descriptionKey, locale, { label: label.toLowerCase() });
const seoText = ti(`category.${categoryKey}.seoText`, locale, {});
const hasSeoText = seoText !== `category.${categoryKey}.seoText`;
const canonical = Astro.url.href;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://colotopia.com';
const enCatSlug = getCategorySlug(categoryKey, 'en');
const altUrl = page.currentPage === 1
  ? `${siteUrl}/en/${enCatSlug}/`
  : `${siteUrl}/en/${enCatSlug}/${page.currentPage}/`;
const firstImage = page.data[0]?.data.image;
const ogImage = firstImage ? `${siteUrl}${firstImage}` : undefined;

const structuredData = pillar && pillar.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'CollectionPage',
          name: page.currentPage === 1
            ? `Coloriages ${label}`
            : `Coloriages ${label} — Page ${page.currentPage}`,
          description: pageDescription,
          url: Astro.url.href,
          numberOfItems: page.total,
        },
        {
          '@type': 'FAQPage',
          mainEntity: pillar.faq.map((f) => ({
            '@type': 'Question',
            name: f.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: f.answer,
            },
          })),
        },
      ],
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: page.currentPage === 1
        ? `Coloriages ${label}`
        : `Coloriages ${label} — Page ${page.currentPage}`,
      description: pageDescription,
      url: Astro.url.href,
    };
---

<BaseLayout
  title={page.currentPage > 1
    ? `Coloriages ${label} — Page ${page.currentPage}`
    : `Coloriages ${label}`}
  description={pageDescription}
  locale={locale}
  canonical={canonical}
  altUrl={altUrl}
  ogImage={ogImage}
  ogImageWidth={800}
  ogImageHeight={1100}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
  category={categoryKey}
>
  <div class="category-hero">
    <div class="category-hero-overlay">
      <span class="category-hero-emoji" aria-hidden="true">{catIcon}</span>
      <h1 class="category-hero-title">Coloriages {label}</h1>
      <p class="category-hero-count">{page.total} coloriages</p>
    </div>
  </div>
  <div class="category-content">
    <Breadcrumb locale={locale} currentPage={`Coloriages ${label}`} />

  {pillar && (
    <p class="pillar-anchor-link">
      <a href="#en-savoir-plus">En savoir plus sur les coloriages {label.toLowerCase()}</a>
    </p>
  )}

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {page.data.map((c: any, i: number) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
        audience={c.data.audience}
        category={c.data.category}
        isLCP={i === 0}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">
      {ti('category.empty', locale, { label: label.toLowerCase() })}
    </p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />

  {pillar && (
    <div id="en-savoir-plus">
      <PillarSection locale={locale} pillar={pillar} categoryLabel={label} />
    </div>
  )}

  {pillar && pillar.faq.length > 0 && (
    <CategoryFaq locale={locale} faq={pillar.faq} categoryLabel={label} />
  )}

  {pillar && pillar.relatedCategories.length > 0 && (
    <RelatedCategories locale={locale} categories={pillar.relatedCategories} />
  )}

  {page.currentPage === 1 && hasSeoText && !pillar && (
    <div class="seo-content" set:html={seoText} />
  )}
  </div>
</BaseLayout>

<style>
  /* Category hero banner — full-bleed within the max-width content box */
  .category-hero {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: var(--category-accent);
    /* Escape main's top padding and side padding */
    margin-top: calc(-1 * var(--space-8));
    margin-left: calc(-1 * var(--space-4));
    margin-right: calc(-1 * var(--space-4));
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .category-hero { height: 280px; }
  }

  .category-hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-6);
    background: rgba(0, 0, 0, 0.2);
  }

  .category-hero-emoji {
    font-size: 3rem;
    line-height: 1;
    margin-bottom: var(--space-2);
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
  }

  .category-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    margin: 0 0 var(--space-2);
    line-height: 1.1;
  }

  .category-hero-count {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.85);
    font-weight: var(--font-weight-semibold);
  }

  /* Page content */
  .category-content {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .coloring-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .coloring-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .pillar-anchor-link {
    margin: var(--space-2) 0 var(--space-4);
    font-size: var(--font-size-sm);
  }

  .pillar-anchor-link a {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-primary-light);
    text-underline-offset: 2px;
  }

  .pillar-anchor-link a:hover {
    color: #4f46e5;
    text-decoration-color: #6366f1;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--font-size-lg);
    padding: var(--space-16) 0;
  }

  .seo-content {
    margin-top: var(--space-10);
    padding: var(--space-6);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }

  .seo-content :global(h2) {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin: var(--space-6) 0 var(--space-3);
  }

  .seo-content :global(h2:first-child) {
    margin-top: 0;
  }

  .seo-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-primary-light);
    text-underline-offset: 2px;
  }

  .seo-content :global(a:hover) {
    color: #4f46e5;
    text-decoration-color: #6366f1;
  }
</style>
