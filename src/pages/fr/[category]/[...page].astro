---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringCard from '../../../components/ColoringCard.astro';
import AdSlot from '../../../components/AdSlot.astro';
import Pagination from '../../../components/Pagination.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PillarSection from '../../../components/PillarSection.astro';
import CategoryFaq from '../../../components/CategoryFaq.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { categories, adultCategories, getCategoryLabel, ti, categoryIcons, categoryColors, type Category } from '../../../lib/i18n';
import { getPillarContent } from '../../../data/pillar-content';

const locale = 'fr';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const results = [];
  for (const cat of categories) {
    const coloriages = await getCollection(
      'coloriages',
      ({ data }) => data.locale === 'fr' && data.category === cat
    );
    const pages = paginate(coloriages, {
      params: { category: cat },
      props: { categoryKey: cat },
      pageSize: 24,
    });
    results.push(...pages);
  }
  return results;
}

const { page, categoryKey } = Astro.props as { page: any; categoryKey: Category };
const label = getCategoryLabel(categoryKey, locale);
const isAdult = (adultCategories as readonly string[]).includes(categoryKey);
const catIcon = categoryIcons[categoryKey];
const catColor = categoryColors[categoryKey];
const pillar = page.currentPage === 1 ? getPillarContent(categoryKey, locale) : null;

const descriptionKey = isAdult ? 'category.description.adults' : 'category.description';
const pageDescription = pillar
  ? pillar.intro.slice(0, 160).replace(/\s+\S*$/, '…')
  : ti(descriptionKey, locale, { label: label.toLowerCase() });
const seoText = ti(`category.${categoryKey}.seoText`, locale, {});
const hasSeoText = seoText !== `category.${categoryKey}.seoText`;
const canonical = Astro.url.href;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://colotopia.com';
const firstImage = page.data[0]?.data.image;
const ogImage = firstImage ? `${siteUrl}${firstImage}` : undefined;

const structuredData = pillar && pillar.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'CollectionPage',
          name: page.currentPage === 1
            ? `Coloriages ${label}`
            : `Coloriages ${label} — Page ${page.currentPage}`,
          description: pageDescription,
          url: Astro.url.href,
          numberOfItems: page.total,
        },
        {
          '@type': 'FAQPage',
          mainEntity: pillar.faq.map((f) => ({
            '@type': 'Question',
            name: f.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: f.answer,
            },
          })),
        },
      ],
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: page.currentPage === 1
        ? `Coloriages ${label}`
        : `Coloriages ${label} — Page ${page.currentPage}`,
      description: pageDescription,
      url: Astro.url.href,
    };
---

<BaseLayout
  title={page.currentPage > 1
    ? `Coloriages ${label} — Page ${page.currentPage}`
    : `Coloriages ${label}`}
  description={pageDescription}
  locale={locale}
  canonical={canonical}
  ogImage={ogImage}
  ogImageWidth={800}
  ogImageHeight={1100}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <Breadcrumb locale={locale} currentPage={`Coloriages ${label}`} />
  <div class:list={['category-hero', { 'category-hero--adult': isAdult }]} style={`background: ${catColor.gradient};`}>
    <span class="category-hero-icon">{catIcon}</span>
    <h1>Coloriages {label}</h1>
    <p class="category-description" style={isAdult ? undefined : `color: ${catColor.text};`}>
      {pillar
        ? ti(isAdult ? 'category.description.adults' : 'category.description', locale, { label: label.toLowerCase() })
        : pageDescription}
    </p>
  </div>

  {pillar && (
    <PillarSection locale={locale} pillar={pillar} categoryLabel={label} />
  )}

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {page.data.map((c: any) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
        audience={c.data.audience}
        category={c.data.category}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">
      {ti('category.empty', locale, { label: label.toLowerCase() })}
    </p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />

  {pillar && pillar.faq.length > 0 && (
    <CategoryFaq locale={locale} faq={pillar.faq} categoryLabel={label} />
  )}

  {pillar && pillar.relatedCategories.length > 0 && (
    <RelatedCategories locale={locale} categories={pillar.relatedCategories} />
  )}

  {page.currentPage === 1 && hasSeoText && !pillar && (
    <div class="seo-content" set:html={seoText} />
  )}
</BaseLayout>

<style>
  .category-hero {
    margin-bottom: 2rem;
    padding: 2rem 1.5rem;
    border-radius: 16px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .category-hero-icon {
    display: block;
    font-size: 3rem;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .category-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  .category-hero--adult h1 {
    color: #ffffff;
  }

  .category-description {
    margin: 0;
    font-size: 0.95rem;
    opacity: 0.85;
  }

  .category-hero--adult .category-description {
    color: #c7d2fe;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }

  .seo-content {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    color: #6b7280;
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .seo-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #374151;
    margin: 1.5rem 0 0.75rem;
  }

  .seo-content :global(h2:first-child) {
    margin-top: 0;
  }

  .seo-content :global(a) {
    color: #6366f1;
    text-decoration: underline;
    text-decoration-color: #c7d2fe;
    text-underline-offset: 2px;
  }

  .seo-content :global(a:hover) {
    color: #4f46e5;
    text-decoration-color: #6366f1;
  }
</style>
