---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColoringCard from '../../components/ColoringCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const locale = 'fr';
const allColoriages = await getCollection('coloriages', ({ data }) => data.locale === locale);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Coloriages Gratuits à Imprimer',
  description:
    'Des centaines de coloriages gratuits à imprimer pour les enfants.',
  url: Astro.url.href,
};
---

<BaseLayout locale={locale} structuredData={structuredData}>
  <section class="hero">
    <h1>Coloriages Gratuits à Imprimer</h1>
    <p>
      Des centaines de coloriages originaux pour les enfants. Téléchargez,
      imprimez et coloriez !
    </p>
  </section>

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {allColoriages.map((c) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
      />
    ))}
  </section>

  {allColoriages.length === 0 && (
    <p class="empty-state">
      Les coloriages arrivent bientôt ! Revenez nous voir.
    </p>
  )}
</BaseLayout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .hero p {
    font-size: 1.1rem;
    color: #6b7280;
    max-width: 600px;
    margin: 0 auto;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
