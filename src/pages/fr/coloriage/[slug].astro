---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringPage from '../../../components/ColoringPage.astro';
import { getCollection } from 'astro:content';
import type { Category } from '../../../lib/i18n';

export async function getStaticPaths() {
  const coloriages = await getCollection('coloriages', ({ data }) => data.locale === 'fr');
  return coloriages.map((c) => ({
    params: { slug: c.data.slug },
    props: { coloring: c },
  }));
}

const { coloring } = Astro.props;
const { title, image, alt, category, tags, slug, seoTitle, seoDescription } = coloring.data;

const locale = 'fr' as const;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://colotopia.com';
const canonicalUrl = `${siteUrl}/fr/coloriage/${slug}`;
const altUrl = `${siteUrl}/en/coloring/${slug}`;

const pageTitle = seoTitle ?? `Coloriage ${title} a imprimer gratuitement | Coloriages`;
const pageDescription =
  seoDescription ??
  `Télécharge et imprime gratuitement ce coloriage de ${title}. Format A4, haute qualité, parfait pour les enfants.`;

const allFr = await getCollection('coloriages', ({ data }) => data.locale === 'fr');
const related = allFr
  .filter((c) => c.data.category === category)
  .map((c) => ({ title: c.data.title, slug: c.data.slug, image: c.data.image, alt: c.data.alt }));

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ImageObject',
      '@id': `${canonicalUrl}#image`,
      name: title,
      description: pageDescription,
      contentUrl: `${siteUrl}${image}`,
      thumbnailUrl: `${siteUrl}${image}`,
      encodingFormat: 'image/png',
    },
    {
      '@type': 'WebPage',
      '@id': canonicalUrl,
      name: pageTitle,
      description: pageDescription,
      url: canonicalUrl,
      inLanguage: 'fr-FR',
      primaryImageOfPage: { '@id': `${canonicalUrl}#image` },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={locale}
  canonical={canonicalUrl}
  ogImage={`${siteUrl}${image}`}
  structuredData={structuredData}
>
  <ColoringPage
    title={title}
    image={image}
    alt={alt}
    category={category as Category}
    tags={tags}
    locale={locale}
    slug={slug}
    related={related}
  />
</BaseLayout>
