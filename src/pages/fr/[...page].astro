---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColoringCard from '../../components/ColoringCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { getPublishableColoriages } from '../../lib/coloriages';
import { t } from '../../lib/i18n';

const PAGE_SIZE = 24;
const locale = 'fr';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allColoriages = await getPublishableColoriages('fr');
  return paginate(allColoriages, { pageSize: 24 });
}

const { page } = Astro.props as { page: any };
const isFirstPage = page.currentPage === 1;
const canonical = Astro.url.href;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://colotopia.com';
const firstImage = page.data[0]?.data.image;
const ogImage = firstImage ? `${siteUrl}${firstImage}` : undefined;

// Nouveaux: 10 most recent by createdAt (only on page 1)
let nouveaux: typeof page.data = [];
let nouveauxSlugs = new Set<string>();
if (isFirstPage) {
  const allColoriages = await getPublishableColoriages('fr');
  nouveaux = allColoriages
    .filter((c: any) => c.data.createdAt)
    .sort((a: any, b: any) => (b.data.createdAt || '').localeCompare(a.data.createdAt || ''))
    .slice(0, 10);
  nouveauxSlugs = new Set(nouveaux.map((c: any) => c.data.slug));
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: page.currentPage === 1
    ? 'Coloriages Gratuits à Imprimer'
    : `Coloriages Gratuits à Imprimer — Page ${page.currentPage}`,
  description: 'Des centaines de coloriages gratuits à imprimer pour les enfants.',
  url: Astro.url.href,
};
---

<BaseLayout
  locale={locale}
  title={page.currentPage > 1 ? `Coloriages Gratuits — Page ${page.currentPage}` : undefined}
  canonical={canonical}
  ogImage={ogImage}
  ogImageWidth={800}
  ogImageHeight={1100}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <section class="hero">
    <!-- Decorative SVG elements -->
    <svg class="deco deco-pencil" width="60" height="60" viewBox="0 0 60 60" fill="none" aria-hidden="true">
      <rect x="20" y="5" width="12" height="44" rx="2" fill="#FBBF24" opacity="0.7"/>
      <polygon points="20,49 32,49 26,58" fill="#F472B6" opacity="0.6"/>
      <rect x="20" y="5" width="12" height="6" rx="1" fill="#4ECDC4" opacity="0.5"/>
    </svg>
    <svg class="deco deco-star" width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
      <path d="M24 4l5.5 13.5L44 19l-11 9.5L36 44l-12-7.5L12 44l3-15.5L4 19l14.5-1.5z" fill="#FBBF24" opacity="0.5"/>
    </svg>
    <svg class="deco deco-splash" width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="14" fill="#4ECDC4" opacity="0.35"/>
      <circle cx="18" cy="18" r="6" fill="#A855F7" opacity="0.3"/>
      <circle cx="48" cy="22" r="5" fill="#F472B6" opacity="0.35"/>
      <circle cx="44" cy="48" r="7" fill="#FBBF24" opacity="0.3"/>
    </svg>
    <svg class="deco deco-dots" width="50" height="50" viewBox="0 0 50 50" fill="none" aria-hidden="true">
      <circle cx="10" cy="10" r="4" fill="#e8437f" opacity="0.3"/>
      <circle cx="30" cy="8" r="3" fill="#4ECDC4" opacity="0.35"/>
      <circle cx="45" cy="20" r="5" fill="#FBBF24" opacity="0.3"/>
      <circle cx="15" cy="35" r="3.5" fill="#A855F7" opacity="0.3"/>
    </svg>
    <h1>{t('site.title', locale)}</h1>
    <p>{t('home.hero.subtitle', locale)}</p>
  </section>

  {isFirstPage && nouveaux.length > 0 && (
    <section class="nouveaux-section">
      <div class="section-header">
        <h2>{t('home.nouveaux.title', locale)}</h2>
        <span class="section-sub">{t('home.nouveaux.subtitle', locale)}</span>
      </div>
      <div class="nouveaux-grid">
        {nouveaux.map((c: any) => (
          <ColoringCard
            title={c.data.title}
            slug={c.data.slug}
            image={c.data.image}
            alt={c.data.alt}
            locale={locale}
            audience={c.data.audience}
            category={c.data.category}
            isNew={true}
          />
        ))}
      </div>
    </section>
  )}

  <AdSlot adSlot="" format="horizontal" />

  <div class="audience-filter" role="group" aria-label="Filtrer par audience">
    <button class="filter-btn active" data-filter="all">{t('home.filter.all', locale)}</button>
    <button class="filter-btn" data-filter="enfants">{t('audience.enfants', locale)}</button>
    <button class="filter-btn" data-filter="adultes">{t('audience.adultes', locale)}</button>
  </div>

  <section class="coloring-grid" id="main-grid">
    {page.data.map((c: any) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
        audience={c.data.audience}
        category={c.data.category}
        isNew={nouveauxSlugs.has(c.data.slug)}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">{t('home.empty', locale)}</p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const grid = document.getElementById('main-grid');
    if (!grid) return;

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        btns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        grid.querySelectorAll<HTMLElement>('[data-audience]').forEach((card) => {
          if (!filter || filter === 'all') {
            card.style.display = '';
          } else {
            card.style.display = card.dataset.audience === filter ? '' : 'none';
          }
        });
      });
    });
  });
</script>

<style>
  .hero {
    text-align: center;
    margin-bottom: 2rem;
    background: linear-gradient(135deg, #fce7f3 0%, #fef3c7 35%, #d1fae5 65%, #e0e7ff 100%);
    border-radius: 20px;
    padding: 2.5rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .deco {
    position: absolute;
    pointer-events: none;
  }

  .deco-pencil {
    top: 0.75rem;
    left: 1.5rem;
    transform: rotate(-15deg);
  }

  .deco-star {
    top: 0.5rem;
    right: 2rem;
    animation: deco-float 4s ease-in-out infinite;
  }

  .deco-splash {
    bottom: 0.5rem;
    left: 3rem;
  }

  .deco-dots {
    bottom: 0.5rem;
    right: 1.5rem;
  }

  @keyframes deco-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
    position: relative;
  }

  .hero p {
    font-size: 1.1rem;
    color: #4b5563;
    max-width: 600px;
    margin: 0 auto;
    font-weight: 500;
    position: relative;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 1.75rem;
    }
    .deco {
      display: none;
    }
  }

  .nouveaux-section {
    margin-bottom: 2.5rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1a1a1a;
  }

  .section-sub {
    font-size: 0.9rem;
    color: #9ca3af;
  }

  .nouveaux-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }

  .audience-filter {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.4rem 1.1rem;
    border: 2px solid #e5e7eb;
    border-radius: 50px;
    background: white;
    font-size: 0.9rem;
    font-weight: 600;
    color: #4b5563;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: #f9a8d4;
    color: #e8437f;
  }

  .filter-btn.active {
    background: #e8437f;
    border-color: #e8437f;
    color: white;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
