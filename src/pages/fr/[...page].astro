---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColoringCard from '../../components/ColoringCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { t } from '../../lib/i18n';

const PAGE_SIZE = 24;
const locale = 'fr';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allColoriages = await getCollection('coloriages', ({ data }) => data.locale === 'fr');
  return paginate(allColoriages, { pageSize: 24 });
}

const { page } = Astro.props as { page: any };

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: page.currentPage === 1
    ? 'Coloriages Gratuits à Imprimer'
    : `Coloriages Gratuits à Imprimer — Page ${page.currentPage}`,
  description: 'Des centaines de coloriages gratuits à imprimer pour les enfants.',
  url: Astro.url.href,
};
---

<BaseLayout
  locale={locale}
  title={page.currentPage > 1 ? `Coloriages Gratuits — Page ${page.currentPage}` : undefined}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <section class="hero">
    <h1>{t('site.title', locale)}</h1>
    <p>{t('home.hero.subtitle', locale)}</p>
  </section>

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {page.data.map((c: any) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">{t('home.empty', locale)}</p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />
</BaseLayout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .hero p {
    font-size: 1.1rem;
    color: #6b7280;
    max-width: 600px;
    margin: 0 auto;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
