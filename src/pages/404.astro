---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCategoryLabel, getCategorySlug, getLocalePath, categoryColors, categoryIcons, type Locale } from '../lib/i18n';

// Detect locale from URL prefix; default to FR
const url = Astro.url.pathname;
const locale: Locale = url.startsWith('/en') ? 'en' : 'fr';

const popularCategories = [
  { key: 'animaux' as const, count: 45 },
  { key: 'dinosaures' as const, count: 32 },
  { key: 'vehicules' as const, count: 28 },
  { key: 'nature' as const, count: 36 },
];
---

<BaseLayout
  title={locale === 'fr' ? 'Page introuvable — Colo s\'est perdu' : 'Page not found — Colo got lost'}
  description={locale === 'fr'
    ? 'Cette page n\'existe pas. Explore nos coloriages gratuits à imprimer !'
    : 'This page doesn\'t exist. Explore our free printable coloring pages!'}
  locale={locale}
  noindex={true}
>
  <div class="not-found-page">
    <!-- Mascot -->
    <div class="not-found-illustration" aria-hidden="true">🦎</div>

    <h1 class="not-found-title">
      {locale === 'fr' ? 'Oups\u00a0! Colo s\u2019est perdu\u2026' : 'Oops\u00a0! Colo got lost\u2026'}
    </h1>
    <p class="not-found-subtitle">
      {locale === 'fr'
        ? 'Cette page n\u2019existe pas ou a \u00e9t\u00e9 d\u00e9plac\u00e9e.'
        : 'This page doesn\u2019t exist or has been moved.'}
    </p>

    <!-- Search -->
    <div class="not-found-search">
      <SearchBar locale={locale} showSubmit={true} />
    </div>

    <!-- Popular categories -->
    <div class="not-found-suggestions">
      {popularCategories.map(({ key, count }) => (
        <CategoryCard
          name={getCategoryLabel(key, locale)}
          emoji={categoryIcons[key]}
          count={count}
          color={categoryColors[key].bg}
          href={`${getLocalePath(locale)}/${getCategorySlug(key, locale)}/`}
          locale={locale}
        />
      ))}
    </div>

    <!-- Home button -->
    <a href={getLocalePath(locale)} class="btn-home">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      {locale === 'fr' ? 'Retour \u00e0 l\u2019accueil' : 'Back to home'}
    </a>
  </div>
</BaseLayout>

<style>
  .not-found-page {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-16) var(--content-padding);
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  /* ── Mascot ── */
  .not-found-illustration {
    font-size: 6rem;
    line-height: 1;
    margin-bottom: var(--space-6);
    display: inline-block;
    animation: wobble 2s ease-in-out infinite;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.12));
  }

  @keyframes wobble {
    0%, 100% { transform: rotate(-5deg); }
    50% { transform: rotate(5deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .not-found-illustration {
      animation: none;
    }
  }

  /* ── Copy ── */
  .not-found-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    line-height: var(--line-height-tight);
  }

  .not-found-subtitle {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-8);
    max-width: 420px;
    line-height: var(--line-height-normal);
  }

  /* ── Search bar ── */
  .not-found-search {
    width: 100%;
    max-width: 480px;
    margin-bottom: var(--space-12);
  }

  /* ── Category suggestions ── */
  .not-found-suggestions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    width: 100%;
    max-width: 480px;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 640px) {
    .not-found-suggestions {
      grid-template-columns: repeat(4, 1fr);
      max-width: 720px;
    }
  }

  /* ── Home button ── */
  .btn-home {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-primary);
    color: #ffffff;
    font-family: inherit;
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-base);
    padding: 0.875rem 2rem;
    border-radius: var(--radius-pill);
    text-decoration: none;
    box-shadow: var(--shadow-btn);
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .btn-home:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-primary);
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-home:hover {
      transform: none;
    }
  }
</style>
