---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringCard from '../../../components/ColoringCard.astro';
import AdSlot from '../../../components/AdSlot.astro';
import Pagination from '../../../components/Pagination.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { categories, adultCategories, getCategoryLabel, getCategorySlug, ti, type Category } from '../../../lib/i18n';

const locale = 'en';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const results = [];
  for (const cat of categories) {
    const catSlug = getCategorySlug(cat, 'en');
    const coloriages = await getCollection(
      'coloriages',
      ({ data }) => data.locale === 'en' && data.category === cat
    );
    const pages = paginate(coloriages, {
      params: { category: catSlug },
      props: { categoryKey: cat },
      pageSize: 24,
    });
    results.push(...pages);
  }
  return results;
}

const { page, categoryKey } = Astro.props as { page: any; categoryKey: Category };
const label = getCategoryLabel(categoryKey, locale);
const isAdult = (adultCategories as readonly string[]).includes(categoryKey);

const descriptionKey = isAdult ? 'category.description.adults' : 'category.description';
const pageDescription = ti(descriptionKey, locale, { label: label.toLowerCase() });

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: page.currentPage === 1
    ? `${label} Coloring Pages`
    : `${label} Coloring Pages — Page ${page.currentPage}`,
  description: pageDescription,
  url: Astro.url.href,
};
---

<BaseLayout
  title={page.currentPage > 1
    ? `${label} Coloring Pages — Page ${page.currentPage}`
    : `${label} Coloring Pages`}
  description={pageDescription}
  locale={locale}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <Breadcrumb locale={locale} currentPage={`${label} Coloring Pages`} />
  <div class:list={['category-hero', { 'category-hero--adult': isAdult }]}>
    <h1>{label} Coloring Pages</h1>
    <p class="category-description">{pageDescription}</p>
  </div>

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {page.data.map((c: any) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
        audience={c.data.audience}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">
      {ti('category.empty', locale, { label: label.toLowerCase() })}
    </p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />
</BaseLayout>

<style>
  .category-hero {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border-radius: 16px;
    background: linear-gradient(135deg, #fef9c3 0%, #fce7f3 50%, #dbeafe 100%);
  }

  .category-hero--adult {
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #3730a3 100%);
  }

  .category-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  .category-hero--adult h1 {
    color: #ffffff;
  }

  .category-description {
    color: #6b7280;
    margin: 0;
  }

  .category-hero--adult .category-description {
    color: #c7d2fe;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
