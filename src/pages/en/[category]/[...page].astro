---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringCard from '../../../components/ColoringCard.astro';
import AdSlot from '../../../components/AdSlot.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { categories, getCategoryLabel, getCategorySlug, type Category } from '../../../lib/i18n';

const locale = 'en';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const results = [];
  for (const cat of categories) {
    const catSlug = getCategorySlug(cat, 'en');
    const coloriages = await getCollection(
      'coloriages',
      ({ data }) => data.locale === 'en' && data.category === cat
    );
    const pages = paginate(coloriages, {
      params: { category: catSlug },
      props: { categoryKey: cat },
      pageSize: 24,
    });
    results.push(...pages);
  }
  return results;
}

const { page, categoryKey } = Astro.props as { page: any; categoryKey: Category };
const label = getCategoryLabel(categoryKey, locale);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: page.currentPage === 1
    ? `${label} Coloring Pages`
    : `${label} Coloring Pages — Page ${page.currentPage}`,
  description: `Free printable ${label.toLowerCase()} coloring pages for kids.`,
  url: Astro.url.href,
};
---

<BaseLayout
  title={page.currentPage > 1
    ? `${label} Coloring Pages — Page ${page.currentPage}`
    : `${label} Coloring Pages`}
  description={`Free printable ${label.toLowerCase()} coloring pages.`}
  locale={locale}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <h1>{label} Coloring Pages</h1>
  <p class="category-description">
    Discover our free printable {label.toLowerCase()} coloring pages.
  </p>

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {page.data.map((c: any) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">
      {label} coloring pages coming soon!
    </p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .category-description {
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
