---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringCard from '../../../components/ColoringCard.astro';
import AdSlot from '../../../components/AdSlot.astro';
import Pagination from '../../../components/Pagination.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PillarSection from '../../../components/PillarSection.astro';
import CategoryFaq from '../../../components/CategoryFaq.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { categories, adultCategories, getCategoryLabel, getCategorySlug, ti, categoryIcons, categoryColors, type Category } from '../../../lib/i18n';
import { getPublishableColoriages } from '../../../lib/coloriages';
import { getPillarContent, getRelatedCategories } from '../../../data/pillar-content';
import fs from 'node:fs';

const locale = 'en';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const results = [];
  const allColoriages = await getPublishableColoriages('en');
  for (const cat of categories) {
    const catSlug = getCategorySlug(cat, 'en');
    const coloriages = allColoriages.filter((c) => c.data.category === cat);
    if (coloriages.length === 0) continue;
    const pages = paginate(coloriages, {
      params: { category: catSlug },
      props: { categoryKey: cat },
      pageSize: 24,
    });
    results.push(...pages);
  }
  return results;
}

const { page, categoryKey } = Astro.props as { page: any; categoryKey: Category };
const label = getCategoryLabel(categoryKey, locale);
const isAdult = (adultCategories as readonly string[]).includes(categoryKey);
const catIcon = categoryIcons[categoryKey];
const catColor = categoryColors[categoryKey];
const bannerPng = fs.existsSync(`public/images/banners/${categoryKey}.png`);
const bannerSrc = bannerPng ? `/images/banners/${categoryKey}.png` : `/images/banners/${categoryKey}.svg`;
const hasBanner = bannerPng || fs.existsSync(`public/images/banners/${categoryKey}.svg`);
const pillar = page.currentPage === 1 ? getPillarContent(categoryKey, locale) : null;
const relatedCats = getRelatedCategories(categoryKey, locale);

const descriptionKey = isAdult ? 'category.description.adults' : 'category.description';
const pageDescription = pillar
  ? pillar.intro.slice(0, 160).replace(/\s+\S*$/, '…')
  : ti(descriptionKey, locale, { label: label.toLowerCase() });
const seoText = ti(`category.${categoryKey}.seoText`, locale, {});
const hasSeoText = seoText !== `category.${categoryKey}.seoText`;
const canonical = Astro.url.href;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://colotopia.com';
const altUrl = page.currentPage === 1
  ? `${siteUrl}/fr/${categoryKey}/`
  : `${siteUrl}/fr/${categoryKey}/${page.currentPage}/`;
const firstImage = page.data[0]?.data.image;
const ogImage = firstImage ? `${siteUrl}${firstImage}` : undefined;

const structuredData = pillar && pillar.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'CollectionPage',
          name: page.currentPage === 1
            ? `${label} Coloring Pages`
            : `${label} Coloring Pages — Page ${page.currentPage}`,
          description: pageDescription,
          url: Astro.url.href,
          numberOfItems: page.total,
        },
        {
          '@type': 'FAQPage',
          mainEntity: pillar.faq.map((f) => ({
            '@type': 'Question',
            name: f.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: f.answer,
            },
          })),
        },
      ],
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: page.currentPage === 1
        ? `${label} Coloring Pages`
        : `${label} Coloring Pages — Page ${page.currentPage}`,
      description: pageDescription,
      url: Astro.url.href,
      numberOfItems: page.total,
    };
---

<BaseLayout
  title={page.currentPage > 1
    ? `${label} Coloring Pages — Page ${page.currentPage}`
    : `${label} Coloring Pages`}
  description={pageDescription}
  locale={locale}
  canonical={canonical}
  altUrl={altUrl}
  ogImage={ogImage}
  ogImageWidth={800}
  ogImageHeight={1100}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
  category={categoryKey}
>
  <div class={`category-hero ${hasBanner ? 'has-banner' : ''}`}>
    {hasBanner && <img class="category-hero-bg" src={bannerSrc} alt="" aria-hidden="true" loading="eager" />}
    <div class="category-hero-overlay">
      <h1 class="category-hero-title">{label} Coloring Pages</h1>
    </div>
  </div>
  <div class="category-count-bar">
    <span>{page.total} coloring pages</span>
  </div>
  <div class="category-content">
    <Breadcrumb locale={locale} currentPage={`${label} Coloring Pages`} />

  {pillar && (
    <p class="pillar-anchor-link">
      <a href="#learn-more">Learn more about {label.toLowerCase()} coloring pages</a>
    </p>
  )}

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {page.data.map((c: any, i: number) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
        audience={c.data.audience}
        category={c.data.category}
        isLCP={i === 0}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">
      {ti('category.empty', locale, { label: label.toLowerCase() })}
    </p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />

  {page.currentPage === 1 && relatedCats.length > 0 && (
    <RelatedCategories locale={locale} categories={relatedCats} />
  )}

  {pillar && (
    <div id="learn-more">
      <PillarSection locale={locale} pillar={pillar} categoryLabel={label} />
    </div>
  )}

  {pillar && pillar.faq.length > 0 && (
    <CategoryFaq locale={locale} faq={pillar.faq} categoryLabel={label} />
  )}

  {page.currentPage === 1 && hasSeoText && !pillar && (
    <div class="seo-content" set:html={seoText} />
  )}
  </div>
</BaseLayout>

<style>
  /* Category hero banner — full-bleed within the max-width content box */
  .category-hero {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: var(--category-accent);
    /* Escape main's top padding and side padding */
    margin-top: calc(-1 * var(--space-8));
    margin-left: calc(-1 * var(--space-4));
    margin-right: calc(-1 * var(--space-4));
    margin-bottom: 0;
    width: calc(100% + 2 * var(--space-4));
  }

  @media (min-width: 768px) {
    .category-hero { height: 280px; }
  }

  .category-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .category-hero.has-banner .category-hero-overlay {
    background: rgba(0, 0, 0, 0.25);
  }

  .category-hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-6);
    background: rgba(0, 0, 0, 0.2);
  }

  .category-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    margin: 0;
    line-height: 1.1;
  }

  .category-count-bar {
    display: flex;
    justify-content: flex-end;
    padding: var(--space-3) 0 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary, #6b7280);
    font-weight: var(--font-weight-semibold);
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding-left: var(--space-4);
    padding-right: var(--space-4);
  }

  .category-content {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .coloring-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .coloring-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .pillar-anchor-link {
    margin: 0.5rem 0 1rem;
    font-size: 0.9rem;
  }

  .pillar-anchor-link a {
    color: #6366f1;
    text-decoration: underline;
    text-decoration-color: #c7d2fe;
    text-underline-offset: 2px;
  }

  .pillar-anchor-link a:hover {
    color: #4f46e5;
    text-decoration-color: #6366f1;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--font-size-lg);
    padding: var(--space-16) 0;
  }

  .seo-content {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    color: #6b7280;
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .seo-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #374151;
    margin: 1.5rem 0 0.75rem;
  }

  .seo-content :global(h2:first-child) {
    margin-top: 0;
  }

  .seo-content :global(a) {
    color: #6366f1;
    text-decoration: underline;
    text-decoration-color: #c7d2fe;
    text-underline-offset: 2px;
  }

  .seo-content :global(a:hover) {
    color: #4f46e5;
    text-decoration-color: #6366f1;
  }
</style>
