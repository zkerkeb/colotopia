---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringCard from '../../../components/ColoringCard.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { getCollection } from 'astro:content';
import { categories, getCategoryLabel, getCategorySlug, type Category } from '../../../lib/i18n';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: getCategorySlug(cat, 'en') },
    props: { categoryKey: cat },
  }));
}

const locale = 'en';
const { categoryKey } = Astro.props as { categoryKey: Category };
const label = getCategoryLabel(categoryKey, locale);

const coloriages = await getCollection(
  'coloriages',
  ({ data }) => data.locale === locale && data.category === categoryKey
);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${label} Coloring Pages`,
  description: `Free printable ${label.toLowerCase()} coloring pages for kids.`,
  url: Astro.url.href,
};
---

<BaseLayout
  title={`${label} Coloring Pages`}
  description={`Free printable ${label.toLowerCase()} coloring pages.`}
  locale={locale}
  structuredData={structuredData}
>
  <h1>{label} Coloring Pages</h1>
  <p class="category-description">
    Discover our free printable {label.toLowerCase()} coloring pages.
  </p>

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {coloriages.map((c) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
      />
    ))}
  </section>

  {coloriages.length === 0 && (
    <p class="empty-state">
      {label} coloring pages coming soon!
    </p>
  )}
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .category-description {
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
