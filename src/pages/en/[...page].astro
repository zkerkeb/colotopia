---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColoringCard from '../../components/ColoringCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';

const locale = 'en';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allColoriages = await getCollection('coloriages', ({ data }) => data.locale === 'en');
  return paginate(allColoriages, { pageSize: 24 });
}

const { page } = Astro.props as { page: any };

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: page.currentPage === 1
    ? 'Free Printable Coloring Pages'
    : `Free Printable Coloring Pages — Page ${page.currentPage}`,
  description: 'Hundreds of free printable coloring pages for kids.',
  url: Astro.url.href,
};
---

<BaseLayout
  locale={locale}
  title={page.currentPage > 1 ? `Free Coloring Pages — Page ${page.currentPage}` : undefined}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <section class="hero">
    <h1>Free Printable Coloring Pages</h1>
    <p>
      Hundreds of original coloring pages for kids. Download, print and color!
    </p>
  </section>

  <AdSlot adSlot="" format="horizontal" />

  <section class="coloring-grid">
    {page.data.map((c: any) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">
      Coloring pages coming soon! Check back later.
    </p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />
</BaseLayout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .hero p {
    font-size: 1.1rem;
    color: #6b7280;
    max-width: 600px;
    margin: 0 auto;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
