---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColoringCard from '../../components/ColoringCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { getPublishableColoriages } from '../../lib/coloriages';
import { t } from '../../lib/i18n';

const locale = 'en';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allColoriages = await getPublishableColoriages('en');
  return paginate(allColoriages, { pageSize: 24 });
}

const { page } = Astro.props as { page: any };
const isFirstPage = page.currentPage === 1;
const canonical = Astro.url.href;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://colotopia.com';
const firstImage = page.data[0]?.data.image;
const ogImage = firstImage ? `${siteUrl}${firstImage}` : undefined;

// Nouveaux: 10 most recent by createdAt (only on page 1)
let nouveaux: typeof page.data = [];
if (isFirstPage) {
  const allColoriages = await getPublishableColoriages('en');
  nouveaux = allColoriages
    .filter((c: any) => c.data.createdAt)
    .sort((a: any, b: any) => (b.data.createdAt || '').localeCompare(a.data.createdAt || ''))
    .slice(0, 10);
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: page.currentPage === 1
    ? 'Free Printable Coloring Pages'
    : `Free Printable Coloring Pages — Page ${page.currentPage}`,
  description: 'Hundreds of free printable coloring pages for kids.',
  url: Astro.url.href,
};
---

<BaseLayout
  locale={locale}
  title={page.currentPage > 1 ? `Free Coloring Pages — Page ${page.currentPage}` : undefined}
  canonical={canonical}
  ogImage={ogImage}
  ogImageWidth={800}
  ogImageHeight={1100}
  structuredData={structuredData}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <section class="hero">
    <h1>{t('site.title', locale)}</h1>
    <p>{t('home.hero.subtitle', locale)}</p>
  </section>

  {isFirstPage && nouveaux.length > 0 && (
    <section class="nouveaux-section">
      <div class="section-header">
        <h2>{t('home.nouveaux.title', locale)}</h2>
        <span class="section-sub">{t('home.nouveaux.subtitle', locale)}</span>
      </div>
      <div class="nouveaux-grid">
        {nouveaux.map((c: any) => (
          <ColoringCard
            title={c.data.title}
            slug={c.data.slug}
            image={c.data.image}
            alt={c.data.alt}
            locale={locale}
            audience={c.data.audience}
          />
        ))}
      </div>
    </section>
  )}

  <AdSlot adSlot="" format="horizontal" />

  <div class="audience-filter" role="group" aria-label="Filter by audience">
    <button class="filter-btn active" data-filter="all">{t('home.filter.all', locale)}</button>
    <button class="filter-btn" data-filter="enfants">{t('audience.enfants', locale)}</button>
    <button class="filter-btn" data-filter="adultes">{t('audience.adultes', locale)}</button>
  </div>

  <section class="coloring-grid" id="main-grid">
    {page.data.map((c: any) => (
      <ColoringCard
        title={c.data.title}
        slug={c.data.slug}
        image={c.data.image}
        alt={c.data.alt}
        locale={locale}
        audience={c.data.audience}
      />
    ))}
  </section>

  {page.data.length === 0 && (
    <p class="empty-state">{t('home.empty', locale)}</p>
  )}

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    locale={locale}
  />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const grid = document.getElementById('main-grid');
    if (!grid) return;

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        btns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        grid.querySelectorAll<HTMLElement>('[data-audience]').forEach((card) => {
          if (!filter || filter === 'all') {
            card.style.display = '';
          } else {
            card.style.display = card.dataset.audience === filter ? '' : 'none';
          }
        });
      });
    });
  });
</script>

<style>
  .hero {
    text-align: center;
    margin-bottom: 2rem;
    background: linear-gradient(135deg, #dbeafe 0%, #ede9fe 50%, #fce7f3 100%);
    border-radius: 20px;
    padding: 2.5rem 1.5rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .hero p {
    font-size: 1.1rem;
    color: #4b5563;
    max-width: 600px;
    margin: 0 auto;
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 1.75rem;
    }
  }

  .nouveaux-section {
    margin-bottom: 2.5rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1a1a1a;
  }

  .section-sub {
    font-size: 0.9rem;
    color: #9ca3af;
  }

  .nouveaux-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }

  .audience-filter {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.4rem 1.1rem;
    border: 2px solid #e5e7eb;
    border-radius: 50px;
    background: white;
    font-size: 0.9rem;
    font-weight: 600;
    color: #4b5563;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: #93c5fd;
    color: #2563eb;
  }

  .filter-btn.active {
    background: #2563eb;
    border-color: #2563eb;
    color: white;
  }

  .coloring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: #9ca3af;
    font-size: 1.1rem;
    padding: 4rem 0;
  }
</style>
