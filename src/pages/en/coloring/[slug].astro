---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColoringPage from '../../../components/ColoringPage.astro';
import { getPublishableColoriages, buildSlugMap } from '../../../lib/coloriages';
import { toWebp, toThumb } from '../../../lib/cdn';
import type { Category } from '../../../lib/i18n';

export async function getStaticPaths() {
  const coloriages = await getPublishableColoriages('en');
  const { enToFr } = await buildSlugMap();
  return coloriages.map((c) => ({
    params: { slug: c.data.slug },
    props: { coloring: c, frSlug: enToFr[c.data.slug] },
  }));
}

const { coloring, frSlug } = Astro.props;
const { title, image, alt, category, tags, slug, seoTitle, seoDescription, createdAt } = coloring.data;

const locale = 'en' as const;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://colotopia.com';
const canonicalUrl = `${siteUrl}/en/coloring/${slug}/`;
const altUrl = frSlug ? `${siteUrl}/fr/coloriage/${frSlug}/` : undefined;

const pageTitle = seoTitle ?? `Free ${title} Coloring Page to Print | Coloring Pages`;
const pageDescription =
  seoDescription ??
  `Download and print this free ${title} coloring page. A4 format, high quality, perfect for kids.`;

const allEn = await getPublishableColoriages('en');
const related = allEn
  .filter((c) => c.data.category === category)
  .map((c) => ({ title: c.data.title, slug: c.data.slug, image: c.data.image, alt: c.data.alt }));

const imageWebp = toWebp(image);
const thumbWebp = toThumb(image);

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ImageObject',
      '@id': `${canonicalUrl}#image`,
      name: title,
      description: pageDescription,
      contentUrl: imageWebp,
      thumbnailUrl: thumbWebp,
      encodingFormat: 'image/webp',
      width: 800,
      height: 1100,
    },
    {
      '@type': 'WebPage',
      '@id': canonicalUrl,
      name: pageTitle,
      description: pageDescription,
      url: canonicalUrl,
      inLanguage: 'en-US',
      primaryImageOfPage: { '@id': `${canonicalUrl}#image` },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={locale}
  canonical={canonicalUrl}
  altUrl={altUrl}
  ogImage={image}
  ogImageWidth={800}
  ogImageHeight={1100}
  ogType="article"
  articlePublishedTime={createdAt}
  structuredData={structuredData}
  category={category}
>
  <ColoringPage
    title={title}
    image={image}
    alt={alt}
    category={category as Category}
    tags={tags}
    locale={locale}
    slug={slug}
    related={related}
  />
</BaseLayout>
