---
import BaseLayout from './BaseLayout.astro';
import PdfDownloadButton from '../components/PdfDownloadButton.astro';
import type { Locale } from '../lib/i18n';
import { getCategoryLabel, getLocalePath } from '../lib/i18n';
import type { Category } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  image: string;
  alt: string;
  category: Category;
  tags: string[];
}

const { title, description, locale, image, alt, category, tags } = Astro.props;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ImageObject',
  name: title,
  description: description || title,
  contentUrl: new URL(image, Astro.site).href,
  thumbnailUrl: new URL(image, Astro.site).href,
  encodingFormat: 'image/png',
  isPartOf: {
    '@type': 'WebPage',
    name: title,
    url: Astro.url.href,
  },
};
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  structuredData={structuredData}
  ogImage={new URL(image, Astro.site).href}
>
  <article class="coloring-page">
    <nav class="breadcrumb">
      <a href={getLocalePath(locale)}>
        {locale === 'fr' ? 'Accueil' : 'Home'}
      </a>
      <span>/</span>
      <a href={getLocalePath(locale, `/${category}`)}>
        {getCategoryLabel(category, locale)}
      </a>
      <span>/</span>
      <span>{title}</span>
    </nav>

    <h1>{title}</h1>

    <div class="coloring-content">
      <div class="coloring-image">
        <img src={image} alt={alt} width="800" height="1100" loading="eager" />
      </div>

      <div class="coloring-actions">
        <PdfDownloadButton image={image} title={title} locale={locale} />
        <button class="btn btn-secondary" onclick="window.print()">
          {locale === 'fr' ? '🖨️ Imprimer' : '🖨️ Print'}
        </button>
      </div>

      {tags.length > 0 && (
        <div class="coloring-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .coloring-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: #666;
  }

  .breadcrumb span {
    color: #999;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
  }

  .coloring-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .coloring-image {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
  }

  .coloring-image img {
    max-height: 80vh;
    width: auto;
  }

  .coloring-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background 0.2s;
  }

  .btn-secondary {
    background: #f3f4f6;
    color: #374151;
  }

  .btn-secondary:hover {
    background: #e5e7eb;
  }

  .coloring-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: #eff6ff;
    color: #2563eb;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8rem;
  }

  @media print {
    .coloring-actions,
    .breadcrumb,
    .coloring-tags {
      display: none;
    }

    .coloring-image {
      border: none;
      padding: 0;
    }
  }
</style>
