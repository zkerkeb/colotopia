---
// Toast container component — place once inside <body>, typically in BaseLayout.
// Usage from JS: window.showToast('Message', 'success' | 'error' | 'info')
---

<div class="toast-container" id="toast-container" role="region" aria-live="polite" aria-label="Notifications"></div>

<style>
  .toast-container {
    position: fixed;
    top: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-toast);
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  :global(.toast) {
    background: #ffffff;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card-hover);
    border-left: 4px solid var(--color-primary);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    pointer-events: auto;
    animation: toast-in 0.3s ease-out, toast-out 0.3s ease-in 2.7s forwards;
    max-width: 360px;
    white-space: nowrap;
  }

  :global(.toast--error) {
    border-left-color: var(--color-secondary);
  }

  :global(.toast--success) {
    border-left-color: var(--color-accent-mint);
  }

  @keyframes toast-in {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes toast-out {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.toast) {
      animation: none;
    }
  }
</style>

<script>
  function showToast(message: string, type: 'info' | 'success' | 'error' = 'info') {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `toast toast--${type}`;
    toast.textContent = message;
    container.appendChild(toast);

    setTimeout(() => {
      toast.remove();
    }, 3000);
  }

  // Expose globally for other scripts
  (window as any).showToast = showToast;
</script>
