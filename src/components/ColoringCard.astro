---
import type { Locale } from '../lib/i18n';
import { getLocalePath, getColoringBasePath } from '../lib/i18n';

interface Props {
  title: string;
  slug: string;
  image: string;
  alt: string;
  locale: Locale;
  audience?: string;
}

const { title, slug, image, alt, locale, audience } = Astro.props;
const href = getLocalePath(locale, `/${getColoringBasePath(locale)}/${slug}`);

// Derive WebP thumbnail path from PNG path
// e.g. /images/coloriages/animaux-chat.png → /images/coloriages/thumbs/animaux-chat.webp
const thumbWebp = image.replace('/images/coloriages/', '/images/coloriages/thumbs/').replace(/\.png$/, '.webp');
---

<a href={href} class="coloring-card" data-audience={audience}>
  <div class="card-image">
    <picture>
      <source type="image/webp" srcset={thumbWebp} />
      <img src={image} alt={alt} width="300" height="400" loading="lazy" decoding="async" />
    </picture>
  </div>
  <h3 class="card-title">{title}</h3>
</a>

<style>
  .coloring-card {
    display: block;
    background: white;
    border: 2px solid #f3f4f6;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .coloring-card:hover {
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.12);
    transform: translateY(-3px);
    border-color: #bfdbfe;
    text-decoration: none;
  }

  .card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f9fafb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-title {
    padding: 0.75rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1a1a1a;
    text-align: center;
  }
</style>
