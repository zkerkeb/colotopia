---
import type { Locale } from '../lib/i18n';
import type { Category } from '../lib/i18n';
import { getLocalePath, getColoringBasePath, categoryIcons } from '../lib/i18n';

interface Props {
  title: string;
  slug: string;
  image: string;
  alt: string;
  locale: Locale;
  audience?: string;
  category?: Category;
  isNew?: boolean;
  isLCP?: boolean;
}

const { title, slug, image, alt, locale, audience, category, isNew, isLCP = false } = Astro.props;
const href = getLocalePath(locale, `/${getColoringBasePath(locale)}/${slug}`);
const icon = category ? categoryIcons[category] : undefined;
const newLabel = locale === 'fr' ? 'Nouveau' : 'New';

// Derive WebP thumbnail path from PNG path
// e.g. /images/coloriages/animaux-chat.png → /images/coloriages/thumbs/animaux-chat.webp
const thumbWebp = image.replace('/images/coloriages/', '/images/coloriages/thumbs/').replace(/\.png$/, '.webp');
---

<a href={href} class="coloring-card" data-audience={audience} data-fade-in>
  {isNew && <span class="badge-new">{newLabel}</span>}
  <div class="card-image-wrapper">
    <picture>
      <source
        type="image/webp"
        srcset={thumbWebp}
        sizes="(max-width: 639px) 50vw, (max-width: 1023px) 33vw, 25vw"
      />
      <img
        src={image}
        alt={alt}
        width="300"
        height="400"
        loading={isLCP ? 'eager' : 'lazy'}
        decoding="async"
        fetchpriority={isLCP ? 'high' : undefined}
      />
    </picture>
    <div class="card-overlay" aria-hidden="true">
      <div class="card-overlay-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </div>
    </div>
  </div>
  <div class="card-body">
    <p class="card-title">{icon && <span class="card-cat-icon">{icon}</span>}{title}</p>
  </div>
</a>

<style>
  .coloring-card {
    display: block;
    position: relative;
    background: #ffffff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    text-decoration: none;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .coloring-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
  }

  .coloring-card:active {
    transform: scale(0.97);
    box-shadow: var(--shadow-sm);
    transition-duration: 80ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .coloring-card:hover,
    .coloring-card:active {
      transform: none;
    }
  }

  .badge-new {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--color-secondary-dark);
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 3px 8px;
    border-radius: 8px;
    z-index: 2;
  }

  .card-image-wrapper {
    aspect-ratio: 3 / 4;
    background: #f8f8f8;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    position: relative;
    overflow: hidden;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(108, 92, 231, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .coloring-card:hover .card-overlay {
    opacity: 1;
  }

  .card-overlay-icon {
    width: 48px;
    height: 48px;
    background: #ffffff;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    color: var(--color-primary);
  }

  .card-body {
    padding: var(--space-3) var(--space-4);
  }

  .card-title {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-cat-icon {
    margin-right: 0.25rem;
  }
</style>
