---
import type { Locale } from '../lib/i18n';
import type { Category } from '../lib/i18n';
import { getLocalePath, getColoringBasePath, categoryIcons } from '../lib/i18n';

interface Props {
  title: string;
  slug: string;
  image: string;
  alt: string;
  locale: Locale;
  audience?: string;
  category?: Category;
  isNew?: boolean;
}

const { title, slug, image, alt, locale, audience, category, isNew } = Astro.props;
const href = getLocalePath(locale, `/${getColoringBasePath(locale)}/${slug}`);
const icon = category ? categoryIcons[category] : undefined;
const newLabel = locale === 'fr' ? 'Nouveau' : 'New';

// Derive WebP thumbnail path from PNG path
// e.g. /images/coloriages/animaux-chat.png → /images/coloriages/thumbs/animaux-chat.webp
const thumbWebp = image.replace('/images/coloriages/', '/images/coloriages/thumbs/').replace(/\.png$/, '.webp');
---

<a href={href} class="coloring-card" data-audience={audience}>
  {isNew && <span class="badge-new">{newLabel}</span>}
  <div class="card-image">
    <picture>
      <source type="image/webp" srcset={thumbWebp} />
      <img src={image} alt={alt} width="300" height="400" loading="lazy" decoding="async" />
    </picture>
  </div>
  <h3 class="card-title">{icon && <span class="card-cat-icon">{icon}</span>}{title}</h3>
</a>

<style>
  .coloring-card {
    display: block;
    position: relative;
    background: white;
    border: 2px solid #f3f4f6;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .coloring-card:hover {
    box-shadow: 0 6px 20px rgba(232, 67, 127, 0.15);
    transform: translateY(-3px);
    border-color: #f9a8d4;
    text-decoration: none;
  }

  .badge-new {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: linear-gradient(135deg, #f472b6, #e8437f);
    color: white;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
    z-index: 1;
    box-shadow: 0 2px 6px rgba(232, 67, 127, 0.3);
  }

  .card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f9fafb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-title {
    padding: 0.75rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1a1a1a;
    text-align: center;
  }

  .card-cat-icon {
    margin-right: 0.25rem;
  }
</style>
