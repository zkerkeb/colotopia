---
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = locale === 'fr' ? 'Fournitures recommandées' : 'Recommended Supplies';
const cta = locale === 'fr' ? 'Voir sur Amazon' : 'View on Amazon';

const tag = 'colotopia-21';
const base = 'https://www.amazon.fr/s';

const products = [
  {
    name: locale === 'fr' ? 'Crayons de couleur (24 pcs)' : 'Colored Pencils (24 pcs)',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'crayons de couleur 24 enfant' : 'colored pencils 24 kids')}&tag=${tag}`,
  },
  {
    name: locale === 'fr' ? 'Feutres lavables' : 'Washable Markers',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'feutres lavables enfant' : 'washable markers kids')}&tag=${tag}`,
  },
  {
    name: locale === 'fr' ? 'Cahier de coloriage' : 'Coloring Book',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'cahier coloriage enfant' : 'kids coloring book')}&tag=${tag}`,
  },
  {
    name: locale === 'fr' ? 'Papier dessin épais' : 'Thick Drawing Paper',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'papier dessin épais enfant' : 'thick drawing paper kids')}&tag=${tag}`,
  },
];
---

<aside class="affiliate-widget">
  <h3>{title}</h3>
  <ul>
    {products.map((product) => (
      <li>
        <span>{product.name}</span>
        <a href={product.link} target="_blank" rel="noopener sponsored nofollow" class="affiliate-link" data-product={product.name}>
          {cta} →
        </a>
      </li>
    ))}
  </ul>
</aside>

<script>
  document.querySelectorAll('.affiliate-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'affiliate_click', {
          product_name: (link as HTMLAnchorElement).dataset.product,
          link_url: (link as HTMLAnchorElement).href,
        });
      }
    });
  });
</script>

<style>
  .affiliate-widget {
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 8px;
    padding: 1rem;
    margin: 2rem 0;
  }

  h3 {
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
    color: #92400e;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  li a {
    color: #b45309;
    font-weight: 500;
    font-size: 0.8rem;
  }

  @media print {
    .affiliate-widget {
      display: none;
    }
  }
</style>
