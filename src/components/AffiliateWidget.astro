---
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = locale === 'fr' ? 'Fournitures recommandées' : 'Recommended Supplies';
const subtitle = locale === 'fr' ? 'Pour de beaux coloriages !' : 'For beautiful coloring!';
const cta = locale === 'fr' ? 'Voir sur Amazon' : 'View on Amazon';

const tag = locale === 'fr' ? 'colotopia-21' : 'colotopiaus-20';
const base = locale === 'fr' ? 'https://www.amazon.fr/s' : 'https://www.amazon.com/s';

const products = [
  {
    name: locale === 'fr' ? 'Crayons de couleur (24 pcs)' : 'Colored Pencils (24 pcs)',
    icon: '🖍️',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'crayons de couleur 24 enfant' : 'colored pencils 24 kids')}&tag=${tag}`,
  },
  {
    name: locale === 'fr' ? 'Feutres lavables' : 'Washable Markers',
    icon: '🖊️',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'feutres lavables enfant' : 'washable markers kids')}&tag=${tag}`,
  },
  {
    name: locale === 'fr' ? 'Cahier de coloriage' : 'Coloring Book',
    icon: '📖',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'cahier coloriage enfant' : 'kids coloring book')}&tag=${tag}`,
  },
  {
    name: locale === 'fr' ? 'Papier dessin épais' : 'Thick Drawing Paper',
    icon: '📄',
    link: `${base}?k=${encodeURIComponent(locale === 'fr' ? 'papier dessin épais enfant' : 'thick drawing paper kids')}&tag=${tag}`,
  },
];
---

<aside class="affiliate-widget">
  <div class="affiliate-header">
    <span class="affiliate-icon">🎨</span>
    <div>
      <h3>{title}</h3>
      <p class="affiliate-subtitle">{subtitle}</p>
    </div>
  </div>
  <ul>
    {products.map((product) => (
      <li>
        <a href={product.link} target="_blank" rel="noopener sponsored nofollow" class="affiliate-link" data-product={product.name}>
          <span class="product-icon">{product.icon}</span>
          <span class="product-name">{product.name}</span>
          <span class="product-cta">{cta} <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>
      </li>
    ))}
  </ul>
</aside>

<script>
  document.querySelectorAll('.affiliate-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'affiliate_click', {
          product_name: (link as HTMLAnchorElement).dataset.product,
          link_url: (link as HTMLAnchorElement).href,
        });
      }
    });
  });
</script>

<style>
  .affiliate-widget {
    background: linear-gradient(135deg, #fdf2f8 0%, #fef3c7 100%);
    border: 2px solid #f9a8d4;
    border-radius: 16px;
    padding: 1.25rem;
    margin: 2rem 0;
  }

  .affiliate-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .affiliate-icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  h3 {
    font-size: 0.9rem;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0;
  }

  .affiliate-subtitle {
    font-size: 0.75rem;
    color: #9ca3af;
    margin: 0;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  li a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    border-radius: 10px;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.6);
    transition: background 0.15s, transform 0.15s;
  }

  li a:hover {
    background: white;
    transform: translateX(2px);
    text-decoration: none;
  }

  .product-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  .product-name {
    flex: 1;
    font-size: 0.8rem;
    font-weight: 600;
    color: #374151;
  }

  .product-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: #e8437f;
    white-space: nowrap;
  }

  @media print {
    .affiliate-widget {
      display: none;
    }
  }
</style>
