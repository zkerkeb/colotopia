---
import type { Locale } from '../lib/i18n';
import { kidsCategories, adultCategories, getCategoryLabel, getCategorySlug, getLocalePath, t, categoryIcons } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav class="category-nav">
  <div class="category-nav-scroll">
    <div class="category-nav-inner">
      <span class="section-label">{t('audience.enfants', locale)}</span>
      {kidsCategories.map((cat) => {
        const href = getLocalePath(locale, `/${getCategorySlug(cat, locale)}`);
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        return (
          <a href={href} class:list={[{ active: isActive }]}>
            <span class="cat-icon">{categoryIcons[cat]}</span>
            {getCategoryLabel(cat, locale)}
          </a>
        );
      })}
      <span class="section-divider" aria-hidden="true">|</span>
      <span class="section-label">{t('audience.adultes', locale)}</span>
      {adultCategories.map((cat) => {
        const href = getLocalePath(locale, `/${getCategorySlug(cat, locale)}`);
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        return (
          <a href={href} class:list={[{ active: isActive }]}>
            <span class="cat-icon">{categoryIcons[cat]}</span>
            {getCategoryLabel(cat, locale)}
          </a>
        );
      })}
    </div>
  </div>
</nav>

<style>
  .category-nav {
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
  }

  .category-nav-scroll {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Gradient fade hints for scroll */
  .category-nav-scroll::before,
  .category-nav-scroll::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 32px;
    pointer-events: none;
    z-index: 1;
  }

  .category-nav-scroll::before {
    left: 0;
    background: linear-gradient(to right, #f9fafb, transparent);
  }

  .category-nav-scroll::after {
    right: 0;
    background: linear-gradient(to left, #f9fafb, transparent);
  }

  .category-nav-inner {
    padding: 0.5rem 1rem;
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    align-items: center;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .category-nav-inner::-webkit-scrollbar {
    display: none;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #9ca3af;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .section-divider {
    color: #d1d5db;
    font-size: 1rem;
    margin: 0 0.25rem;
  }

  .category-nav-inner a {
    white-space: nowrap;
    color: #4b5563;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .cat-icon {
    font-size: 1em;
    line-height: 1;
  }

  .category-nav-inner a:hover {
    background: #fce7f3;
    color: #be185d;
  }

  .category-nav-inner a.active {
    background: #fce7f3;
    color: #be185d;
    font-weight: 600;
  }

  @media print {
    .category-nav {
      display: none;
    }
  }
</style>
