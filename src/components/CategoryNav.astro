---
import type { Locale } from '../lib/i18n';
import { kidsCategories, adultCategories, getCategoryLabel, getCategorySlug, getLocalePath, t } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<nav class="category-nav">
  <div class="category-nav-inner">
    <span class="section-label">{t('audience.enfants', locale)}</span>
    {kidsCategories.map((cat) => (
      <a href={getLocalePath(locale, `/${getCategorySlug(cat, locale)}`)}>
        {getCategoryLabel(cat, locale)}
      </a>
    ))}
    <span class="section-divider" aria-hidden="true">|</span>
    <span class="section-label">{t('audience.adultes', locale)}</span>
    {adultCategories.map((cat) => (
      <a href={getLocalePath(locale, `/${getCategorySlug(cat, locale)}`)}>
        {getCategoryLabel(cat, locale)}
      </a>
    ))}
  </div>
</nav>

<style>
  .category-nav {
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
  }

  .category-nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.5rem 1rem;
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    align-items: center;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #9ca3af;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .section-divider {
    color: #d1d5db;
    font-size: 1rem;
    margin: 0 0.25rem;
  }

  .category-nav-inner a {
    white-space: nowrap;
    color: #4b5563;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .category-nav-inner a:hover {
    background: #e5e7eb;
    color: #1f2937;
  }

  @media print {
    .category-nav {
      display: none;
    }
  }
</style>
