---
/**
 * ColoringPage — main coloring page template component
 * Assembles: hero image, download/print actions, related pages, ads, affiliate widget
 */
import Breadcrumb from './Breadcrumb.astro';
import PdfDownloadButton from './PdfDownloadButton.astro';
import RelatedColoriages from './RelatedColoriages.astro';
import AdSlot from './AdSlot.astro';
import AffiliateWidget from './AffiliateWidget.astro';
import type { Locale } from '../lib/i18n';
import type { Category } from '../lib/i18n';
import { t, getLocalePath, getColoringBasePath } from '../lib/i18n';

interface RelatedItem {
  title: string;
  slug: string;
  image: string;
  alt: string;
}

interface Props {
  title: string;
  image: string;
  alt: string;
  category: Category;
  tags: string[];
  locale: Locale;
  slug: string;
  related?: RelatedItem[];
}

const {
  title,
  image,
  alt,
  category,
  tags,
  locale,
  slug,
  related = [],
} = Astro.props;

const printLabel = `🖨️ ${t('coloring.print', locale)}`;

// Derive WebP path from PNG path (original PNG kept for PDF generation)
// e.g. /images/coloriages/animaux-chat.png → /images/coloriages/animaux-chat.webp
const imageWebp = image.replace(/\.png$/, '.webp');

// Social sharing URLs
const siteUrl = 'https://colotopia.com';
const pageUrl = `${siteUrl}${getLocalePath(locale, `/${getColoringBasePath(locale)}/${slug}`)}/`;
const shareText = `${title} - ${t('site.title', locale)}`;
const imageAbsUrl = `${siteUrl}${image}`;
const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(`${shareText} ${pageUrl}`)}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
const pinterestUrl = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(pageUrl)}&media=${encodeURIComponent(imageAbsUrl)}&description=${encodeURIComponent(shareText)}`;
---

<article class="coloring-page">
  <!-- Above-fold banner ad -->
  <AdSlot adSlot="" format="horizontal" />

  <Breadcrumb locale={locale} category={category} currentPage={title} />

  <h1>{title}</h1>

  <div class="page-layout">
    <!-- Main content -->
    <div class="main-content">
      <div class="coloring-image">
        <picture>
          <source type="image/webp" srcset={imageWebp} />
          <img src={image} alt={alt} width="800" height="1100" loading="eager" decoding="async" fetchpriority="high"
            data-pin-url={pageUrl}
            data-pin-description={shareText}
            data-pin-media={imageAbsUrl}
          />
        </picture>
      </div>

      <div class="coloring-actions">
        <PdfDownloadButton image={image} title={title} locale={locale} />
        <button class="btn btn-secondary" id="print-btn" onclick="if(typeof gtag==='function'){gtag('event','print_page',{page_title:document.title});}window.print();">
          {printLabel}
        </button>
      </div>

      {tags.length > 0 && (
        <div class="coloring-tags">
          {tags.map((tag) => (
            <a class="tag" href={`${getLocalePath(locale)}?q=${encodeURIComponent(tag)}`}>{tag}</a>
          ))}
        </div>
      )}

      <!-- Social sharing -->
      <div class="share-section">
        <span class="share-label">{t('share.label', locale)} :</span>
        <div class="share-buttons">
          <a href={pinterestUrl} class="share-btn share-pinterest" target="_blank" rel="noopener noreferrer" aria-label={t('share.pinterest', locale)}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            Pinterest
          </a>
          <a href={whatsappUrl} class="share-btn share-whatsapp" target="_blank" rel="noopener noreferrer" aria-label={t('share.whatsapp', locale)}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={facebookUrl} class="share-btn share-facebook" target="_blank" rel="noopener noreferrer" aria-label={t('share.facebook', locale)}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
        </div>
      </div>

      <!-- Below-content ad -->
      <AdSlot adSlot="" format="rectangle" />

      <RelatedColoriages locale={locale} items={related} currentSlug={slug} />
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">
      <AdSlot adSlot="" format="vertical" />
      <AffiliateWidget locale={locale} />
    </aside>
  </div>
</article>

<style>
  .coloring-page {
    max-width: 1100px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
    line-height: 1.2;
  }

  .page-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 860px) {
    .page-layout {
      grid-template-columns: 1fr;
    }
  }

  .coloring-image {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .coloring-image img {
    max-height: 80vh;
    width: auto;
    max-width: 100%;
  }

  .coloring-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background 0.2s;
  }

  .btn-secondary {
    background: #f3f4f6;
    color: #374151;
  }

  .btn-secondary:hover {
    background: #e5e7eb;
  }

  .coloring-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    background: #eff6ff;
    color: #2563eb;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .tag:hover {
    background: #dbeafe;
    color: #1d4ed8;
    text-decoration: none;
  }

  .share-section {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .share-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #6b7280;
  }

  .share-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .share-btn:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .share-whatsapp {
    background: #25d366;
    color: white;
  }

  .share-facebook {
    background: #1877f2;
    color: white;
  }

  .share-pinterest {
    background: #e60023;
    color: white;
  }

  .sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media print {
    .coloring-actions,
    .coloring-tags,
    .sidebar {
      display: none;
    }

    .page-layout {
      display: block;
    }

    .coloring-image {
      border: none;
      padding: 0;
    }
  }
</style>
