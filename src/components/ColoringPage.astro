---
/**
 * ColoringPage — main coloring page template component
 * Assembles: hero image, download/print actions, related pages, ads, affiliate widget
 */
import Breadcrumb from './Breadcrumb.astro';
import PdfDownloadButton from './PdfDownloadButton.astro';
import RelatedColoriages from './RelatedColoriages.astro';
import AdSlot from './AdSlot.astro';
import AffiliateWidget from './AffiliateWidget.astro';
import type { Locale } from '../lib/i18n';
import type { Category } from '../lib/i18n';
import { t, getLocalePath, getColoringBasePath, categoryColors, categoryIcons } from '../lib/i18n';

interface RelatedItem {
  title: string;
  slug: string;
  image: string;
  alt: string;
}

interface Props {
  title: string;
  image: string;
  alt: string;
  category: Category;
  tags: string[];
  locale: Locale;
  slug: string;
  related?: RelatedItem[];
}

const {
  title,
  image,
  alt,
  category,
  tags,
  locale,
  slug,
  related = [],
} = Astro.props;

const printLabel = t('coloring.print', locale);
const catColor = categoryColors[category];
const catIcon = categoryIcons[category];

// Derive WebP path from PNG path (original PNG kept for PDF generation)
// e.g. /images/coloriages/animaux-chat.png → /images/coloriages/animaux-chat.webp
const imageWebp = image.replace(/\.png$/, '.webp');

// Social sharing URLs
const siteUrl = 'https://colotopia.com';
const pageUrl = `${siteUrl}${getLocalePath(locale, `/${getColoringBasePath(locale)}/${slug}`)}/`;
const shareText = `${title} - ${t('site.title', locale)}`;
const imageAbsUrl = `${siteUrl}${image}`;
const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(`${shareText} ${pageUrl}`)}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
const pinterestUrl = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(pageUrl)}&media=${encodeURIComponent(imageAbsUrl)}&description=${encodeURIComponent(shareText)}`;

const shareLabel = t('share.label', locale);
const mobileActionsTitle = t('mobile.actions.title', locale);
const mobileShareLabel = t('mobile.actions.share', locale);
const mobilePrintLabel = t('mobile.actions.print', locale);
const mobileCancelLabel = t('mobile.actions.cancel', locale);
const downloadLabel = t('coloring.download', locale);
---

<script define:vars={{ title, category, slug, tags }}>
  // GA4: track coloring page view
  if (typeof window.gtag === 'function') {
    window.gtag('event', 'coloring_view', {
      coloring_title: title,
      coloring_category: category,
      coloring_slug: slug,
      coloring_tags: tags.join(','),
    });
  }
</script>

<article class="coloring-page">
  <!-- Above-fold banner ad -->
  <AdSlot adSlot="" format="horizontal" />

  <Breadcrumb locale={locale} category={category} currentPage={title} />

  <h1 class="page-title">{title}</h1>

  <div class="page-layout">
    <!-- Main content -->
    <div class="main-content">
      <!-- A4 paper frame -->
      <div class="coloring-image-frame" style={`--category-color: ${catColor.bg}`}>
        <div class="coloring-image">
          <picture>
            <source type="image/webp" srcset={imageWebp} />
            <img
              src={image}
              alt={alt}
              width="800"
              height="1100"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              data-pin-url={pageUrl}
              data-pin-description={shareText}
              data-pin-media={imageAbsUrl}
            />
          </picture>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="coloring-actions">
        <PdfDownloadButton image={image} title={title} locale={locale} />
        <button
          class="btn-print btn-lg"
          id="print-btn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          {printLabel}
        </button>
      </div>

      <!-- Mobile action sheet (share/print/download) -->
      <div class="action-sheet-overlay" id="action-sheet-overlay" hidden>
        <div class="action-sheet" role="dialog" aria-label={mobileActionsTitle}>
          <div class="action-sheet-header">{mobileActionsTitle}</div>
          <button class="action-sheet-btn" id="action-share" data-share-title={shareText} data-share-url={pageUrl}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            {mobileShareLabel}
          </button>
          <button class="action-sheet-btn" id="action-download">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {downloadLabel}
          </button>
          <button class="action-sheet-btn" id="action-print">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            {mobilePrintLabel}
          </button>
          <button class="action-sheet-btn action-sheet-cancel" id="action-cancel">{mobileCancelLabel}</button>
        </div>
      </div>

      <script>
        // Mobile action sheet: on small screens, print button opens the sheet instead of window.print()
        const printBtn = document.getElementById('print-btn');
        const overlay = document.getElementById('action-sheet-overlay');
        const shareBtn = document.getElementById('action-share');
        const downloadBtn = document.getElementById('action-download');
        const actionPrintBtn = document.getElementById('action-print');
        const cancelBtn = document.getElementById('action-cancel');

        function isMobile() {
          return window.matchMedia('(max-width: 860px)').matches;
        }

        function closeSheet() {
          if (overlay) overlay.hidden = true;
        }

        function openSheet() {
          if (overlay) overlay.hidden = false;
        }

        if (printBtn) {
          printBtn.addEventListener('click', () => {
            if (isMobile()) {
              openSheet();
            } else {
              if (typeof window.gtag === 'function') {
                window.gtag('event', 'print_page', { page_title: document.title });
              }
              window.print();
            }
          });
        }

        // Close on overlay click
        if (overlay) {
          overlay.addEventListener('click', (e) => {
            if (e.target === overlay) closeSheet();
          });
        }

        if (cancelBtn) cancelBtn.addEventListener('click', closeSheet);

        // Share via Web Share API
        if (shareBtn) {
          shareBtn.addEventListener('click', async () => {
            closeSheet();
            const shareTitle = shareBtn.dataset.shareTitle || document.title;
            const shareUrl = shareBtn.dataset.shareUrl || window.location.href;
            if (navigator.share) {
              try {
                await navigator.share({ title: shareTitle, url: shareUrl });
                if (typeof window.gtag === 'function') {
                  window.gtag('event', 'share', { method: 'native', content_type: 'coloring_page', item_id: window.location.pathname });
                }
              } catch (_) { /* user cancelled */ }
            } else {
              // Fallback: copy URL
              try {
                await navigator.clipboard.writeText(shareUrl);
              } catch (_) {}
            }
          });
        }

        // Download PDF — trigger existing PDF button
        if (downloadBtn) {
          downloadBtn.addEventListener('click', () => {
            closeSheet();
            const pdfBtn = document.getElementById('pdf-download-btn');
            if (pdfBtn) pdfBtn.click();
          });
        }

        // Print from action sheet
        if (actionPrintBtn) {
          actionPrintBtn.addEventListener('click', () => {
            closeSheet();
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'print_page', { page_title: document.title });
            }
            window.print();
          });
        }
      </script>

      <!-- Mobile supply widget (hidden on desktop where sidebar shows it) -->
      <div class="mobile-supplies">
        <AffiliateWidget locale={locale} />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="coloring-tags">
          {tags.map((tag) => (
            <a class="tag" href={`${getLocalePath(locale)}?q=${encodeURIComponent(tag)}`}>{tag}</a>
          ))}
        </div>
      )}

      <!-- Social sharing -->
      <div class="share-section">
        <span class="share-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          {shareLabel}
        </span>
        <div class="share-buttons">
          <a href={pinterestUrl} class="share-btn share-pinterest" target="_blank" rel="noopener noreferrer" aria-label={t('share.pinterest', locale)}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            Pinterest
          </a>
          <a href={whatsappUrl} class="share-btn share-whatsapp" target="_blank" rel="noopener noreferrer" aria-label={t('share.whatsapp', locale)}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={facebookUrl} class="share-btn share-facebook" target="_blank" rel="noopener noreferrer" aria-label={t('share.facebook', locale)}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
        </div>
      </div>

      <script>
        // GA4: track share button clicks
        document.querySelectorAll('.share-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            if (typeof window.gtag === 'function') {
              const platform = btn.classList.contains('share-pinterest') ? 'pinterest'
                : btn.classList.contains('share-whatsapp') ? 'whatsapp'
                : btn.classList.contains('share-facebook') ? 'facebook' : 'unknown';
              window.gtag('event', 'share', {
                method: platform,
                content_type: 'coloring_page',
                item_id: window.location.pathname,
              });
            }
          });
        });
      </script>

      <!-- Below-content ad -->
      <AdSlot adSlot="" format="rectangle" />

      <RelatedColoriages locale={locale} items={related} currentSlug={slug} />
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">
      <AdSlot adSlot="" format="vertical" />
      <AffiliateWidget locale={locale} />
    </aside>
  </div>
</article>

<style>
  .coloring-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-text);
    line-height: var(--line-height-tight);
    margin: var(--space-4) 0 var(--space-6);
  }

  .page-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--space-8);
    align-items: start;
  }

  .mobile-supplies {
    display: none;
  }

  @media (max-width: 860px) {
    .page-layout {
      grid-template-columns: 1fr;
    }

    .mobile-supplies {
      display: block;
    }

    .sidebar {
      display: none;
    }
  }

  /* ── A4 Paper frame ── */
  .coloring-image-frame {
    background: #ffffff;
    border-radius: var(--radius-lg);
    border-top: 4px solid var(--category-color, var(--color-primary));
    box-shadow:
      0 2px 6px rgba(0, 0, 0, 0.06),
      0 8px 24px rgba(0, 0, 0, 0.09),
      0 24px 56px rgba(0, 0, 0, 0.05);
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  .coloring-image {
    padding: var(--space-6);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
  }

  .coloring-image img {
    width: 100%;
    height: auto;
    max-height: 80vh;
    object-fit: contain;
    display: block;
  }

  /* ── Action buttons ── */
  .coloring-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .btn-lg {
    padding: 0.875rem 2rem;
    font-size: var(--font-size-lg);
    border-radius: var(--radius-md);
    gap: var(--space-2);
  }

  .btn-print {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    border: 2px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
    font-family: inherit;
  }

  .btn-print:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* ── Tags ── */
  .coloring-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .tag {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .tag:hover {
    background: var(--color-primary);
    color: var(--color-text-inverse);
    text-decoration: none;
  }

  /* ── Share section ── */
  .share-section {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
  }

  .share-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .share-buttons {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-pill);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .share-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .share-whatsapp { background: #25d366; color: #ffffff; }
  .share-facebook { background: #1877f2; color: #ffffff; }
  .share-pinterest { background: #e60023; color: #ffffff; }

  /* ── Sidebar ── */
  .sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--space-4));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* ── Mobile action sheet ── */
  .action-sheet-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    animation: fadeIn 0.15s ease-out;
  }

  .action-sheet-overlay[hidden] {
    display: none;
  }

  .action-sheet {
    width: 100%;
    max-width: 500px;
    background: var(--color-bg-card, #fff);
    border-radius: var(--radius-lg, 1rem) var(--radius-lg, 1rem) 0 0;
    padding: var(--space-4, 1rem);
    padding-bottom: calc(var(--space-4, 1rem) + env(safe-area-inset-bottom, 0px));
    animation: slideUp 0.2s ease-out;
  }

  .action-sheet-header {
    text-align: center;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-text-secondary, #666);
    padding-bottom: var(--space-3, 0.75rem);
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    margin-bottom: var(--space-2, 0.5rem);
  }

  .action-sheet-btn {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    width: 100%;
    padding: var(--space-4, 1rem) var(--space-3, 0.75rem);
    border: none;
    background: none;
    font-size: var(--font-size-base, 1rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-text, #1a1a2e);
    cursor: pointer;
    border-radius: var(--radius-sm, 0.5rem);
    font-family: inherit;
    transition: background var(--transition-fast, 0.15s);
  }

  .action-sheet-btn:hover {
    background: var(--color-bg-subtle, #f5f5f5);
  }

  .action-sheet-btn:active {
    background: var(--color-primary-light, #e8e0ff);
  }

  .action-sheet-cancel {
    margin-top: var(--space-2, 0.5rem);
    border-top: 1px solid var(--color-border, #e5e7eb);
    color: var(--color-text-secondary, #666);
    justify-content: center;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media print {
    .coloring-page {
      padding: 0 !important;
      margin: 0 !important;
      max-width: none !important;
    }

    .page-title,
    .coloring-actions,
    .coloring-tags,
    .share-section,
    .mobile-supplies,
    .sidebar,
    .action-sheet-overlay,
    .main-content > :not(.coloring-image-frame) {
      display: none !important;
    }

    .page-layout {
      display: block !important;
      gap: 0;
    }

    .main-content {
      padding: 0;
      margin: 0;
    }

    .coloring-image-frame {
      border: none !important;
      box-shadow: none !important;
      border-top: none !important;
      border-radius: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      page-break-inside: avoid;
      break-inside: avoid;
      page-break-after: avoid;
      break-after: avoid;
    }

    .coloring-image {
      padding: 0 !important;
      margin: 0 !important;
      width: 100%;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .coloring-image img {
      width: 100%;
      height: 100vh;
      max-height: none;
      object-fit: contain;
    }
  }
</style>
