---
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
  showSubmit?: boolean;
}

const { locale, showSubmit = false } = Astro.props;

const action = `/${locale}`;
const submitLabel = locale === 'fr' ? 'Chercher' : 'Search';
const ariaLabel = locale === 'fr' ? 'Rechercher un coloriage' : 'Search for a coloring page';
const noResults = locale === 'fr' ? 'Aucun résultat' : 'No results';
const indexUrl = `/${locale}/search-index.json`;

const placeholdersFr = [
  'Cherche un dinosaure…',
  'Cherche une princesse…',
  'Cherche un robot…',
  'Cherche un mandala…',
  'Cherche un animal…',
];
const placeholdersEn = [
  'Search for a dinosaur…',
  'Search for a princess…',
  'Search for a robot…',
  'Search for a mandala…',
  'Search for an animal…',
];
const defaultPlaceholder = locale === 'fr' ? placeholdersFr[0] : placeholdersEn[0];
const placeholders = JSON.stringify(locale === 'fr' ? placeholdersFr : placeholdersEn);
---

<form
  class:list={['search-bar', showSubmit && 'search-bar--hero']}
  action={action}
  method="get"
  id="search-bar"
  data-index-url={indexUrl}
  data-no-results={noResults}
  data-placeholders={placeholders}
  role="search"
>
  <div class="search-input-wrapper">
    <span class="search-icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
    </span>
    <input
      type="search"
      name="q"
      class="search-input"
      placeholder={defaultPlaceholder}
      autocomplete="off"
      aria-label={ariaLabel}
      aria-expanded="false"
      aria-controls="search-results"
    />
    <ul class="search-results" id="search-results" role="listbox" hidden></ul>
  </div>
  {showSubmit && (
    <button type="submit" class="btn-primary search-submit">{submitLabel}</button>
  )}
</form>

<style>
  .search-bar {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex: 1;
    max-width: 400px;
    width: 100%;
  }

  .search-bar--hero {
    max-width: 560px;
  }

  @media (max-width: 480px) {
    .search-bar--hero {
      flex-direction: column;
    }
    .search-bar--hero .search-input-wrapper {
      width: 100%;
    }
    .search-bar--hero .search-submit {
      width: 100%;
      justify-content: center;
    }
  }

  .search-input-wrapper {
    position: relative;
    flex: 1;
  }

  .search-icon {
    position: absolute;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
    display: flex;
    align-items: center;
  }

  .search-input {
    width: 100%;
    padding: 12px var(--space-4) 12px 2.75rem;
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    border: 2px solid transparent;
    border-radius: var(--radius-lg);
    background: #ffffff;
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    color: var(--color-text);
    outline: none;
  }

  .search-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-focus);
  }

  .search-input::-webkit-search-cancel-button {
    cursor: pointer;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    list-style: none;
    margin: 0;
    padding: var(--space-1) 0;
    z-index: var(--z-dropdown);
    max-height: 320px;
    overflow-y: auto;
  }

  .search-results[hidden] {
    display: none;
  }

  .search-results :global(.search-result-item) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .search-results :global(.search-result-item:hover),
  .search-results :global(.search-result-item[aria-selected="true"]) {
    background: var(--color-primary-light);
  }

  .search-results :global(.search-result-item:hover .search-result-title),
  .search-results :global(.search-result-item[aria-selected="true"] .search-result-title) {
    color: var(--color-primary);
  }

  .search-results :global(.search-result-title) {
    font-weight: var(--font-weight-medium);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-results :global(.search-result-category) {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    background: var(--color-bg-subtle);
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .search-results :global(.search-no-results) {
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    pointer-events: none;
  }
</style>

<script>
  const bar = document.getElementById('search-bar') as HTMLFormElement;
  if (bar) {
    const input = bar.querySelector<HTMLInputElement>('.search-input')!;
    const results = bar.querySelector<HTMLUListElement>('.search-results')!;
    const indexUrl = bar.dataset.indexUrl!;
    const noResultsText = bar.dataset.noResults!;
    const placeholders: string[] = JSON.parse(bar.dataset.placeholders || '[]');

    let index: Array<{ title: string; slug: string; tags: string[]; category: string; categoryLabel?: string; url: string }> = [];
    let loaded = false;
    let debounceTimer: ReturnType<typeof setTimeout>;
    let selectedIndex = -1;

    // Rotating placeholder
    if (placeholders.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let pi = 0;
      setInterval(() => {
        pi = (pi + 1) % placeholders.length;
        input.style.opacity = '0.6';
        setTimeout(() => {
          input.placeholder = placeholders[pi];
          input.style.opacity = '1';
        }, 150);
      }, 2500);
      input.style.transition = 'opacity 150ms ease';
    }

    async function loadIndex() {
      if (loaded) return;
      loaded = true;
      try {
        const res = await fetch(indexUrl);
        index = await res.json();
      } catch {
        loaded = false;
      }
    }

    function normalize(s: string) {
      return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function search(query: string) {
      const q = normalize(query.trim());
      if (!q) return [];
      return index
        .filter((item) => {
          const inTitle = normalize(item.title).includes(q);
          const inTags = item.tags.some((t) => normalize(t).includes(q));
          const inCategory = normalize(item.category).includes(q);
          return inTitle || inTags || inCategory;
        })
        .slice(0, 8);
    }

    function renderResults(items: typeof index) {
      results.innerHTML = '';
      selectedIndex = -1;
      if (items.length === 0) {
        const li = document.createElement('li');
        li.className = 'search-no-results';
        li.textContent = noResultsText;
        results.appendChild(li);
      } else {
        items.forEach((item) => {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = item.url;
          a.className = 'search-result-item';
          a.setAttribute('role', 'option');
          const label = item.categoryLabel || item.category;
          a.innerHTML = `<span class="search-result-title">${item.title}</span><span class="search-result-category">${label}</span>`;
          li.appendChild(a);
          results.appendChild(li);
        });
      }
      results.hidden = false;
      input.setAttribute('aria-expanded', 'true');
    }

    function closeResults() {
      results.hidden = true;
      input.setAttribute('aria-expanded', 'false');
      selectedIndex = -1;
    }

    function getLinks() {
      return Array.from(results.querySelectorAll<HTMLAnchorElement>('.search-result-item'));
    }

    function selectItem(idx: number) {
      const links = getLinks();
      links.forEach((l, i) => l.setAttribute('aria-selected', i === idx ? 'true' : 'false'));
      selectedIndex = idx;
    }

    input.addEventListener('focus', loadIndex);

    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const val = input.value;
        if (!val.trim()) { closeResults(); return; }
        const hits = search(val);
        renderResults(hits);
      }, 250);
    });

    input.addEventListener('keydown', (e) => {
      const links = getLinks();
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectItem(Math.min(selectedIndex + 1, links.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectItem(Math.max(selectedIndex - 1, 0));
      } else if (e.key === 'Enter' && selectedIndex >= 0) {
        e.preventDefault();
        links[selectedIndex]?.click();
      } else if (e.key === 'Escape') {
        closeResults();
        input.blur();
      }
    });

    document.addEventListener('click', (e) => {
      if (!bar.contains(e.target as Node)) closeResults();
    });

    // Auto-trigger search from ?q= URL param
    const urlQ = new URLSearchParams(window.location.search).get('q');
    if (urlQ) {
      input.value = urlQ;
      loadIndex().then(() => {
        const hits = search(urlQ);
        renderResults(hits);
        input.focus();
      });
    }
  }
</script>
