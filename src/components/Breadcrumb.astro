---
import type { Locale } from '../lib/i18n';
import { t, getCategoryLabel, getCategorySlug, getLocalePath } from '../lib/i18n';
import type { Category } from '../lib/i18n';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  locale: Locale;
  category?: Category;
  currentPage: string;
}

const { locale, category, currentPage } = Astro.props;

const items: BreadcrumbItem[] = [
  { label: t('nav.home', locale), href: getLocalePath(locale) },
];

if (category) {
  items.push({
    label: getCategoryLabel(category, locale),
    href: getLocalePath(locale, `/${getCategorySlug(category, locale)}`),
  });
}

items.push({ label: currentPage });

const schemaItems = items.map((item, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: item.label,
  ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
}));
---

<nav class="breadcrumb" aria-label="breadcrumb">
  <ol>
    {items.map((item, i) => (
      <li>
        {i > 0 && <span class="sep" aria-hidden="true">/</span>}
        {item.href ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
})} />

<style>
  .breadcrumb {
    margin-bottom: 1.5rem;
  }

  ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    font-size: 0.875rem;
    color: #6b7280;
  }

  li {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .sep {
    color: #d1d5db;
  }

  a {
    color: #e8437f;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  span[aria-current="page"] {
    color: #374151;
    font-weight: 500;
  }

  @media print {
    .breadcrumb {
      display: none;
    }
  }
</style>
