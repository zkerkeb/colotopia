---
import type { Locale } from '../lib/i18n';
import { t, getCategoryLabel, getCategorySlug, getLocalePath } from '../lib/i18n';
import type { Category } from '../lib/i18n';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  locale: Locale;
  category?: Category;
  currentPage: string;
}

const { locale, category, currentPage } = Astro.props;

const ariaLabel = locale === 'fr' ? 'Fil d\'Ariane' : 'Breadcrumb';

const items: BreadcrumbItem[] = [
  { label: t('nav.home', locale), href: getLocalePath(locale) },
];

if (category) {
  items.push({
    label: getCategoryLabel(category, locale),
    href: getLocalePath(locale, `/${getCategorySlug(category, locale)}`),
  });
}

items.push({ label: currentPage });

const schemaItems = items.map((item, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: item.label,
  ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
}));
---

<nav aria-label={ariaLabel}>
  <ol class="breadcrumb">
    {items.map((item, i) => (
      <>
        <li class:list={['breadcrumb-item', !item.href && 'breadcrumb-item--current']}>
          {item.href ? (
            <a href={item.href} class="breadcrumb-link">
              <span>{item.label}</span>
            </a>
          ) : (
            <span class="breadcrumb-current" aria-current="page">{item.label}</span>
          )}
        </li>
        {i < items.length - 1 && (
          <li class="breadcrumb-separator" aria-hidden="true">›</li>
        )}
      </>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
})} />

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
  }

  .breadcrumb-separator {
    color: var(--color-primary);
    font-size: 1.1rem;
    font-weight: var(--font-weight-semibold);
    margin: 0 var(--space-2);
    list-style: none;
  }

  .breadcrumb-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumb-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .breadcrumb-current {
    color: var(--color-text);
    font-weight: var(--font-weight-bold);
  }

  @media print {
    nav { display: none; }
  }
</style>
