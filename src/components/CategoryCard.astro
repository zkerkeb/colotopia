---
interface Props {
  name: string;
  slug: string;
  emoji: string;
  count: number;
  color: string;
  href: string;
  locale?: string;
  image?: string;
}

const { name, emoji, count, color, href, locale = 'fr', image } = Astro.props;
const countLabel = locale === 'fr' ? `${count} coloriages` : `${count} coloring pages`;
---

<a
  href={href}
  class={`category-card${image ? ' category-card--image' : ''}`}
  style={`--category-color: ${color}`}
  aria-label={`${name} — ${countLabel}`}
  data-fade-in
>
  {image
    ? <>
        <img class="category-cover" src={image} alt={name} loading="lazy" />
        <span class="category-image-label">
          <span class="category-image-label__text">{name}</span>
        </span>
      </>
    : <>
        <span class="category-emoji" aria-hidden="true">{emoji}</span>
        <span class="category-name">{name}</span>
        <span class="category-count">{countLabel}</span>
      </>
  }
</a>

<style>
  .category-card {
    background: var(--category-color, var(--color-accent-mint));
    border-radius: var(--radius-xl);
    padding: var(--space-4) var(--space-4) var(--space-5);
    text-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    transition: box-shadow var(--transition-normal);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .category-card:hover {
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
  }

  .category-card--image {
    padding: 0;
    aspect-ratio: 1 / 1;
    position: relative;
  }

  .category-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-xl);
    transition: transform 0.3s ease;
  }

  .category-card--image:hover .category-cover {
    transform: scale(1.04);
  }

  .category-image-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 22% 8% 8%;
    background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, transparent 100%);
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
  }

  .category-image-label__text {
    font-family: 'Fredoka One', cursive;
    font-weight: 400;
    font-size: clamp(1rem, 4.5vw, 1.35rem);
    color: #fff;
    text-align: center;
    letter-spacing: 0.04em;
    line-height: 1.1;
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
  }

  .category-emoji {
    font-size: 2.5rem;
    line-height: 1;
  }

  .category-name {
    font-family: var(--font-body);
    font-weight: var(--font-weight-extrabold);
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  .category-count {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: rgba(45, 52, 54, 0.7);
  }
</style>
