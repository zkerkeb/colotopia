---
interface Props {
  name: string;
  slug: string;
  emoji: string;
  count: number;
  color: string;
  href: string;
  locale?: string;
  image?: string;
}

const { name, emoji, count, color, href, locale = 'fr', image } = Astro.props;
const countLabel = locale === 'fr' ? `${count} coloriages` : `${count} coloring pages`;
---

{image ? (
  <a
    href={href}
    class="category-card category-card--image"
    aria-label={`${name} — ${countLabel}`}
    data-fade-in
  >
    <img class="category-cover" src={image} alt={name} loading="lazy" />
    <div class="category-overlay">
      <span class="category-name">{name}</span>
      <span class="category-count">{countLabel}</span>
    </div>
  </a>
) : (
  <a
    href={href}
    class="category-card"
    style={`--category-color: ${color}`}
    aria-label={`${name} — ${countLabel}`}
    data-fade-in
  >
    <span class="category-emoji" aria-hidden="true">{emoji}</span>
    <span class="category-name">{name}</span>
    <span class="category-count">{countLabel}</span>
  </a>
)}

<style>
  .category-card {
    background: var(--category-color, var(--color-accent-mint));
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    transition: box-shadow var(--transition-normal);
    box-shadow: var(--shadow-card);
  }

  .category-card--image {
    position: relative;
    padding: 0;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: #f5f0eb;
  }

  .category-card--image:hover {
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
  }

  .category-card--image:hover .category-cover {
    transform: scale(1.04);
  }

  .category-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .category-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-3) var(--space-4) var(--space-4);
    background: linear-gradient(to top, rgba(255,255,255,0.92) 60%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .category-card:hover {
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
  }

  .category-emoji {
    font-size: 2.5rem;
    line-height: 1;
  }

  .category-name {
    font-family: var(--font-body);
    font-weight: var(--font-weight-extrabold);
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  .category-count {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: rgba(45, 52, 54, 0.7);
  }
</style>
