---
import type { Locale } from '../lib/i18n';

interface Props {
  image: string;
  locale: Locale;
}

const { image, locale } = Astro.props;
const label = locale === 'fr' ? '📥 Télécharger le PDF' : '📥 Download PDF';
---

<a href={image} download class="btn btn-primary pdf-download">
  {label}
</a>

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: background 0.2s;
    background: #2563eb;
    color: white;
  }

  .btn-primary:hover {
    background: #1d4ed8;
    text-decoration: none;
  }

  @media print {
    .pdf-download {
      display: none;
    }
  }
</style>
