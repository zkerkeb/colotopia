---
import ColoringCard from './ColoringCard.astro';
import type { Locale } from '../lib/i18n';

interface ColoringEntry {
  title: string;
  slug: string;
  image: string;
  alt: string;
}

interface Props {
  locale: Locale;
  items: ColoringEntry[];
  currentSlug?: string;
}

const { locale, items, currentSlug } = Astro.props;

const related = items
  .filter((c) => c.slug !== currentSlug)
  .slice(0, 6);

const heading = locale === 'fr' ? 'Coloriages similaires' : 'Similar Coloring Pages';
---

{related.length > 0 && (
  <section class="related-coloriages">
    <h2>{heading}</h2>
    <div class="related-grid">
      {related.map((c) => (
        <ColoringCard
          title={c.title}
          slug={c.slug}
          image={c.image}
          alt={c.alt}
          locale={locale}
        />
      ))}
    </div>
  </section>
)}

<style>
  .related-coloriages {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 2px solid var(--color-border);
  }

  h2 {
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 480px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 768px) {
    .related-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media print {
    .related-coloriages {
      display: none;
    }
  }
</style>
