---
import ColoringCard from './ColoringCard.astro';
import type { Locale } from '../lib/i18n';

interface ColoringEntry {
  title: string;
  slug: string;
  image: string;
  alt: string;
}

interface Props {
  locale: Locale;
  items: ColoringEntry[];
  currentSlug?: string;
}

const { locale, items, currentSlug } = Astro.props;

const related = items
  .filter((c) => c.slug !== currentSlug)
  .slice(0, 6);

const heading = locale === 'fr' ? 'Coloriages similaires' : 'Similar Coloring Pages';
---

{related.length > 0 && (
  <section class="related-coloriages">
    <h2>{heading}</h2>
    <div class="related-grid">
      {related.map((c) => (
        <ColoringCard
          title={c.title}
          slug={c.slug}
          image={c.image}
          alt={c.alt}
          locale={locale}
        />
      ))}
    </div>
  </section>
)}

<style>
  .related-coloriages {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media print {
    .related-coloriages {
      display: none;
    }
  }
</style>
