---
import type { Locale } from '../lib/i18n';
import { t, kidsCategories, adultCategories, getCategoryLabel, getCategorySlug, getLocalePath, getPrivacyPath, getTermsPath } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const tagline = locale === 'fr' ? 'Des coloriages gratuits pour tous les âges !' : 'Free coloring pages for all ages!';
const infoTitle = locale === 'fr' ? 'Informations' : 'Info';
const contactLabel = locale === 'fr' ? 'Contact' : 'Contact';
const allRights = locale === 'fr' ? 'Tous droits réservés' : 'All rights reserved';
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Brand row -->
    <div class="footer-brand">
      <a href={getLocalePath(locale)} class="footer-logo-link" aria-label="Colotopia">
        <img src="/images/colotopia-logo.svg" alt="Colotopia" class="footer-logo" width="240" height="44" />
      </a>
      <p class="footer-tagline">{tagline}</p>

      <!-- Social icons -->
      <div class="footer-social" aria-label="Réseaux sociaux">
        <a href="https://pinterest.com/colotopia" class="social-icon" aria-label="Pinterest" rel="noopener noreferrer" target="_blank">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
          </svg>
        </a>
        <a href="https://instagram.com/colotopia" class="social-icon" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Links grid -->
    <div class="footer-grid">
      <div class="footer-column">
        <h4 class="footer-column-title">{t('footer.kids', locale)}</h4>
        <ul class="footer-link-list">
          {kidsCategories.map((cat) => (
            <li>
              <a href={getLocalePath(locale, `/${getCategorySlug(cat, locale)}`)} class="footer-link">
                {getCategoryLabel(cat, locale)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-column-title">{t('footer.adults', locale)}</h4>
        <ul class="footer-link-list">
          {adultCategories.map((cat) => (
            <li>
              <a href={getLocalePath(locale, `/${getCategorySlug(cat, locale)}`)} class="footer-link">
                {getCategoryLabel(cat, locale)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-column-title">{infoTitle}</h4>
        <ul class="footer-link-list">
          <li><a href={getPrivacyPath(locale)} class="footer-link">{t('footer.privacy', locale)}</a></li>
          <li><a href={getTermsPath(locale)} class="footer-link">{t('footer.terms', locale)}</a></li>
          <li><a href="mailto:contact@colotopia.com" class="footer-link">{contactLabel}</a></li>
        </ul>
      </div>
    </div>

    <!-- Copyright bar -->
    <div class="footer-bottom">
      <span>&copy; {year} Colotopia. {allRights}.</span>
      <span class="footer-made">Made with ❤️ for kids</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #2d3436;
    color: rgba(255, 255, 255, 0.9);
    padding: var(--space-16) var(--content-padding) var(--space-8);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Brand */
  .footer-brand {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .footer-logo-link {
    display: inline-block;
    text-decoration: none;
    margin-bottom: var(--space-3);
  }

  .footer-logo {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    transition: opacity var(--transition-fast);
  }

  .footer-logo-link:hover .footer-logo {
    opacity: 1;
  }

  .footer-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-5);
  }

  /* Social icons */
  .footer-social {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
  }

  .social-icon {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .social-icon:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #ffffff;
    text-decoration: none;
  }

  /* Link grid */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  .footer-column-title {
    font-family: var(--font-body);
    font-weight: var(--font-weight-extrabold);
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-accent-mint);
    margin-bottom: var(--space-4);
  }

  .footer-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-link {
    display: block;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: #ffffff;
    text-decoration: none;
  }

  /* Copyright bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.45);
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  @media print {
    .site-footer {
      display: none;
    }
  }
</style>
