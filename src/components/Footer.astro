---
import type { Locale } from '../lib/i18n';
import { t, kidsCategories, adultCategories, getCategoryLabel, getCategorySlug, getLocalePath, getPrivacyPath, getTermsPath } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <!-- Decorative wave separator -->
  <div class="footer-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="none">
      <path d="M0 20c240 30 480-10 720 15s480-20 720 10v35H0z" fill="currentColor"/>
    </svg>
  </div>

  <div class="footer-inner">
    <!-- Footer branding -->
    <div class="footer-brand">
      <a href={getLocalePath(locale)} class="footer-logo">
        <img src="/images/colotopia-logo.png" alt="Colotopia" class="footer-logo-img" width="499" height="391" />
      </a>
      <p class="footer-tagline">
        {locale === 'fr' ? 'Des coloriages gratuits pour tous les âges !' : 'Free coloring pages for all ages!'}
      </p>
    </div>

    <div class="footer-grid">
      <!-- Kids categories -->
      <div class="footer-col">
        <h4>{t('footer.kids', locale)}</h4>
        <ul>
          {kidsCategories.map((cat) => (
            <li>
              <a href={getLocalePath(locale, `/${getCategorySlug(cat, locale)}`)}>
                {getCategoryLabel(cat, locale)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Adult categories -->
      <div class="footer-col">
        <h4>{t('footer.adults', locale)}</h4>
        <ul>
          {adultCategories.map((cat) => (
            <li>
              <a href={getLocalePath(locale, `/${getCategorySlug(cat, locale)}`)}>
                {getCategoryLabel(cat, locale)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal / info -->
      <div class="footer-col">
        <h4>{t('footer.legal', locale)}</h4>
        <ul>
          <li><a href={getPrivacyPath(locale)}>{t('footer.privacy', locale)}</a></li>
          <li><a href={getTermsPath(locale)}>{t('footer.terms', locale)}</a></li>
          <li><a href={`mailto:contact@colotopia.com`}>{t('footer.contact', locale)}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Colotopia. {t('footer.rights', locale)}.</p>
    </div>
  </div>

  <!-- Decorative footer elements -->
  <div class="footer-deco" aria-hidden="true">
    <span class="footer-deco-item" style="left: 5%; bottom: 2rem; font-size: 1.5rem; opacity: 0.15;">🖍️</span>
    <span class="footer-deco-item" style="left: 15%; bottom: 4rem; font-size: 1.25rem; opacity: 0.1;">⭐</span>
    <span class="footer-deco-item" style="right: 8%; bottom: 3rem; font-size: 1.75rem; opacity: 0.12;">🎨</span>
    <span class="footer-deco-item" style="right: 20%; bottom: 5rem; font-size: 1rem; opacity: 0.1;">✏️</span>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: linear-gradient(135deg, #4a1942 0%, #2d1b4e 50%, #1a1145 100%);
    margin-top: 4rem;
    padding: 0 1rem 1.5rem;
    color: #d1d5db;
    font-size: 0.875rem;
    overflow: hidden;
  }

  .footer-wave {
    color: #fffdf9;
    margin: 0 -1rem;
    line-height: 0;
  }

  .footer-wave svg {
    width: 100%;
    height: 40px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .footer-brand {
    text-align: center;
    padding: 1.5rem 0 2rem;
  }

  .footer-logo {
    display: inline-block;
    text-decoration: none;
  }

  .footer-logo-img {
    height: 56px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    transition: opacity 0.15s;
  }

  .footer-logo:hover .footer-logo-img {
    opacity: 1;
  }

  .footer-tagline {
    margin-top: 0.375rem;
    color: #c4b5fd;
    font-size: 0.9rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .footer-col h4 {
    color: #f9a8d4;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-col a {
    color: #a5b4c8;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: #f9a8d4;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.25rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .footer-deco-item {
    position: absolute;
  }

  @media print {
    .site-footer {
      display: none;
    }
  }
</style>
